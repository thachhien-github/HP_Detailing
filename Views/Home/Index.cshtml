@model HP_Detailing.Models.ViewModels.HomeDashboardViewModel
@{ ViewData["Title"] = "Dashboard"; Layout = "_Layout"; }

<div class="p-4 sm:p-6 lg:p-8 space-y-8 min-h-screen">

    @* ===== PAGE HEADER ===== *@
    @await Html.PartialAsync("_PageHeader", new HP_Detailing.Models.PageHeaderModel
    {
        Title = "Chào buổi sáng, HP Auto!",
        Breadcrumbs = new System.Collections.Generic.List<HP_Detailing.Models.PageHeaderBreadcrumb>
        {
            new HP_Detailing.Models.PageHeaderBreadcrumb { Label = "Hệ thống HP Auto" }
        },
        ActionsSlotHtml = @"
            <button onclick=""HPUI.toast('Đang khởi tạo báo cáo ngày...','info'); setTimeout(function(){ HPUI.toast('Báo cáo ngày 15/05 đã sẵn sàng!','success'); },1500);"" class=""px-4 py-2.5 bg-slate-900 border border-slate-800 rounded-lg text-sm font-bold text-slate-300 hover:border-blue-500/50 transition-all flex items-center gap-2"">
                <i data-lucide=""download"" class=""w-4 h-4""></i> Báo cáo ngày
            </button>
            <a href=""/tickets/new"" class=""px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-bold transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)] flex items-center gap-2"">
                <i data-lucide=""plus"" class=""w-4 h-4""></i> Tạo phiếu mới
            </a>"
    })

    @* ===== STAT CARDS ===== *@
    <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5">
        @{
            var stats = new[]
            {
                new { title = "Xe trong xưởng", value = Model.InProgressCars.ToString(), unit = "xe", tag = "+12%", tagCss = "text-emerald-400 bg-emerald-500/10", icon = "car", iconCss = "bg-blue-500/10 border-blue-500/20 text-blue-500", hoverCss = "hover:border-blue-500/50", progress = "" },
                new { title = "Lịch hẹn hôm nay", value = Model.TodayAppointmentsCount.ToString(), unit = "lịch", tag = "Khẩn cấp", tagCss = "text-amber-400 bg-amber-500/10", icon = "clock", iconCss = "bg-amber-500/10 border-amber-500/20 text-amber-500", hoverCss = "hover:border-amber-500/50", progress = "" },
                new { title = "Doanh thu tháng", value = Model.TotalRevenue.ToString("N0"), unit = "VNĐ", tag = "Mục tiêu 85%", tagCss = "text-blue-400 bg-blue-400/10", icon = "circle-dollar-sign", iconCss = "bg-blue-500/10 border-blue-500/20 text-blue-500", hoverCss = "hover:border-blue-500/50", progress = "" },
                new { title = "Dịch vụ hoàn thành", value = Model.CompletedTickets.ToString(), unit = "vé", tag = "", tagCss = "", icon = "check-circle-2", iconCss = "bg-emerald-500/10 border-emerald-500/20 text-emerald-500", hoverCss = "hover:border-emerald-500/50", progress = "92" },
            };
        }
        @foreach (var stat in stats)
        {
            <div class="bg-[#122131] border border-slate-800 p-5 rounded-xl flex flex-col justify-between group transition-all @stat.hoverCss">
                <div class="flex justify-between items-start">
                    <div class="p-2.5 rounded-lg border @stat.iconCss">
                        <i data-lucide="@stat.icon" class="w-5 h-5 pointer-events-none"></i>
                    </div>
                    @if (!string.IsNullOrEmpty(stat.tag))
                    {
                        <span class="text-[10px] font-bold px-2 py-0.5 rounded @stat.tagCss">@stat.tag</span>
                    }
                    else if (!string.IsNullOrEmpty(stat.progress))
                    {
                        <div class="flex items-center gap-2 mt-1">
                            <span class="text-[10px] font-bold text-emerald-400">@(stat.progress)%</span>
                            <div class="w-16 h-1.5 bg-slate-800 rounded-full overflow-hidden">
                                <div class="bg-emerald-500 h-full rounded-full transition-all" style="width: @(stat.progress)%"></div>
                            </div>
                        </div>
                    }
                </div>
                <div class="mt-5">
                    <p class="text-slate-500 text-[11px] font-bold tracking-widest uppercase mb-1">@stat.title</p>
                    <div class="flex items-baseline gap-2">
                        <h3 class="text-3xl font-bold text-slate-100 tracking-tight font-display">@stat.value</h3>
                        <span class="text-xs text-slate-500 font-mono font-medium">@stat.unit</span>
                    </div>
                </div>
            </div>
        }
    </section>

    @* ===== ACTIVE SERVICES TABLE ===== *@
    <section class="space-y-5">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <i data-lucide="clock" class="w-6 h-6 text-blue-500"></i>
                <h3 class="text-xl sm:text-[22px] font-semibold text-slate-200">Phiếu dịch vụ đang xử lý</h3>
            </div>
            <a href="/tickets" class="text-sm font-bold text-blue-400 hover:text-blue-300 transition-colors flex items-center gap-1">
                Xem tất cả <i data-lucide="more-horizontal" class="w-4 h-4"></i>
            </a>
        </div>

        <div class="bg-[#122131]/60 border border-slate-800 rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-900/50 border-b border-slate-800">
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest whitespace-nowrap">Mã phiếu</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest">Khách hàng / Phương tiện</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest">Dịch vụ</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest">Trạng thái</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @foreach (var ticket in Model.RecentTickets)
                        {
                            <tr class="hover:bg-slate-800/30 transition-colors">
                                <td class="px-6 py-4">
                                    <p class="font-mono text-xs font-bold text-blue-400">@ticket.TicketCode</p>
                                    <span class="text-[10px] text-slate-500 mt-1 block">@ticket.CreatedAt.ToString("HH:mm dd/MM")</span>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-[13px] font-bold text-slate-200">@ticket.CustomerName</p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded text-[10px] font-mono font-bold uppercase tracking-wider">@ticket.Plate</span>
                                        <span class="text-xs text-slate-500">@ticket.CarModel</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-wrap gap-1.5">
                                        @{
                                            var statusLabel = ticket.Status switch
                                            {
                                                "in_progress" => "Đang xử lý",
                                                "pending" => "Chờ tiếp nhận",
                                                "completed" => "Đã hoàn thành",
                                                "cancelled" => "Đã hủy",
                                                _ => ticket.Status
                                            };
                                        }
                                        <span class="text-[11px] text-slate-300 bg-slate-800/50 border border-slate-700/50 px-2 py-1 rounded">@statusLabel</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (ticket.Status == "in_progress")
                                    {
                                        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-blue-400 uppercase tracking-widest bg-blue-500/10 border border-blue-500/20 px-2.5 py-1 rounded">
                                            <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span> Đang xử lý
                                        </span>
                                    }
                                    else if (ticket.Status == "pending")
                                    {
                                        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-amber-400 uppercase tracking-widest bg-amber-500/10 border border-amber-500/20 px-2.5 py-1 rounded">
                                            Chờ tiếp nhận
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-400 uppercase tracking-widest bg-slate-500/10 border border-slate-500/20 px-2.5 py-1 rounded">
                                            @statusLabel
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a href="/tickets/@ticket.Id"
                                       class="text-[11px] font-bold bg-blue-500/10 hover:bg-blue-600 hover:text-white border border-blue-500/20 text-blue-400 px-3 py-1.5 rounded transition-all inline-block">
                                        Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    @* ===== QUICK ACTIONS ROW ===== *@
    <section class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <button onclick="HPUI.openModal('paymentModal')"
                class="bg-[#122131] border border-slate-800 rounded-xl p-5 text-left group hover:border-emerald-500/50 transition-all">
            <div class="flex items-center gap-3 mb-3">
                <div class="p-2 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400">
                    <i data-lucide="wallet" class="w-5 h-5"></i>
                </div>
                <h4 class="text-sm font-bold text-slate-200">Thanh toán nhanh</h4>
            </div>
            <p class="text-xs text-slate-500">Xử lý thanh toán cho phiếu dịch vụ đã hoàn thành</p>
        </button>

        <a href="/tickets/new"
           class="bg-[#122131] border border-slate-800 rounded-xl p-5 text-left group hover:border-blue-500/50 transition-all block">
            <div class="flex items-center gap-3 mb-3">
                <div class="p-2 rounded-lg bg-blue-500/10 border border-blue-500/20 text-blue-400">
                    <i data-lucide="file-plus" class="w-5 h-5"></i>
                </div>
                <h4 class="text-sm font-bold text-slate-200">Tạo phiếu dịch vụ</h4>
            </div>
            <p class="text-xs text-slate-500">Tiếp nhận xe mới và tạo phiếu dịch vụ</p>
        </a>

        <a href="/appointments"
           class="bg-[#122131] border border-slate-800 rounded-xl p-5 text-left group hover:border-purple-500/50 transition-all block">
            <div class="flex items-center gap-3 mb-3">
                <div class="p-2 rounded-lg bg-purple-500/10 border border-purple-500/20 text-purple-400">
                    <i data-lucide="calendar" class="w-5 h-5"></i>
                </div>
                <h4 class="text-sm font-bold text-slate-200">Xem lịch hẹn</h4>
            </div>
            <p class="text-xs text-slate-500">Quản lý lịch hẹn khách hàng hôm nay</p>
        </a>
    </section>
</div>

@* ===== PAYMENT MODAL ===== *@
<div id="paymentModal" class="hp-modal-overlay hidden" style="display:none;">
    <div class="hp-modal-content bg-slate-900 border border-slate-800 w-full max-w-lg rounded-xl shadow-2xl overflow-hidden">
        <div class="p-5 border-b border-slate-800 flex justify-between items-center bg-slate-900/50">
            <div class="flex items-center gap-3">
                <i data-lucide="wallet" class="w-5 h-5 text-blue-500"></i>
                <h3 class="text-lg font-bold text-slate-100">Thanh toán hóa đơn</h3>
            </div>
            <button onclick="HPUI.closeModal('paymentModal')" class="text-slate-500 hover:text-white p-1 transition-colors">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>

        <div class="p-6 space-y-6">
            <div class="bg-[#050b14] border border-slate-800 rounded-lg p-5 space-y-3">
                <p class="text-[10px] text-blue-500 font-bold tracking-widest uppercase mb-2">Chi tiết phiếu #HP-0942</p>
                <div class="flex justify-between items-center text-sm">
                    <span class="text-slate-400">Rửa xe bọt tuyết - Gói Gold</span>
                    <span class="font-mono font-medium text-slate-200">250.000 VNĐ</span>
                </div>
                <div class="flex justify-between items-center text-sm">
                    <span class="text-slate-400">Vệ sinh khoang máy tỉ mỉ</span>
                    <span class="font-mono font-medium text-slate-200">850.000 VNĐ</span>
                </div>
                <div class="pt-4 mt-2 border-t border-slate-800 flex justify-between items-center">
                    <span class="font-bold text-slate-300">Tổng cộng:</span>
                    <span class="font-black text-xl text-blue-400">1.100.000 VNĐ</span>
                </div>
            </div>

            <div class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[11px] text-slate-500 font-bold uppercase tracking-widest">Phương thức thanh toán</label>
                        <select id="payMethodSelect" onchange="HPUI.toggleQR(this.value)" class="w-full bg-[#050b14] border border-slate-800 rounded-lg py-2.5 px-3 text-sm text-slate-300 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none">
                            <option value="cash">Tiền mặt</option>
                            <option value="transfer">Chuyển khoản</option>
                            <option value="card">Thẻ (Visa/Master)</option>
                        </select>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[11px] text-slate-500 font-bold uppercase tracking-widest">Số tiền thanh toán</label>
                        <div class="relative">
                            <input type="text" value="1.100.000"
                                   class="w-full bg-[#050b14] border border-slate-800 rounded-lg py-2.5 px-3 text-sm text-slate-200 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 pr-10 font-mono font-medium outline-none" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[10px] text-slate-500 font-bold">VNĐ</span>
                        </div>
                    </div>
                </div>
                
                <div id="qrArea" class="hidden">
                    <div class="bg-white p-3 rounded-xl w-fit mx-auto shadow-2xl border-4 border-slate-800">
                        <img id="qrImage" src="" alt="VietQR" class="w-48 h-48" />
                        <p class="text-center text-[10px] text-slate-900 font-black uppercase tracking-widest mt-2">Quét mã chuyển khoản</p>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[11px] text-slate-500 font-bold uppercase tracking-widest">Ghi chú thanh toán</label>
                    <textarea class="w-full bg-[#050b14] border border-slate-800 rounded-lg py-2.5 px-3 text-sm text-slate-300 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 h-20 resize-none outline-none"
                              placeholder="Nhập ghi chú nếu có..."></textarea>
                </div>
            </div>
        </div>

        <div class="p-5 border-t border-slate-800 bg-slate-900/50 flex gap-3">
            <button onclick="HPUI.closeModal('paymentModal')"
                    class="flex-1 py-3 border border-slate-800 rounded-lg text-sm font-bold text-slate-400 hover:bg-slate-800 transition-all">
                Hủy bỏ
            </button>
            <button onclick="HPUI.toast('Đang xử lý giao dịch thanh toán...','info'); setTimeout(function(){ HPUI.toast('Thanh toán thành công! Đã gửi biên nhận tới khách hàng.','success'); HPUI.closeModal('paymentModal'); },1500);"
                    class="flex-[2] py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-bold transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)] flex items-center justify-center gap-2">
                <i data-lucide="check-circle-2" class="w-5 h-5"></i>
                Xác nhận thanh toán
            </button>
        </div>
    </div>
</div>

    <script>
        (function(){
            // Standard initialization handled by HPUI.reinit()
            
            window.HPUI = window.HPUI || {};
            HPUI.toggleQR = function(val) {
                var qrArea = document.getElementById('qrArea');
                var qrImg = document.getElementById('qrImage');
                if (val === 'transfer') {
                    qrImg.src = HPUI.generateQR(1100000, 'Thanh toan bill HP-0942');
                    qrArea.classList.remove('hidden');
                } else {
                    qrArea.classList.add('hidden');
                }
            };
        })();
    </script>
</div>
