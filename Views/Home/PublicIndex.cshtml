<!-- Section 6: Booking Form -->
<section id="booking" class="py-xl bg-surface-container overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop grid md:grid-cols-2 gap-lg items-center">
        <div class="relative">
            <h2 class="text-display-lg-mobile md:text-headline-md font-headline-md mb-6">Đặt lịch hẹn ngay</h2>
            <p class="text-body-lg font-body-lg text-on-surface-variant mb-8">Để lại thông tin, đội ngũ tư vấn của HP Auto Detailing sẽ liên hệ xác nhận trong vòng 30 phút.</p>
            <div class="space-y-6">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">call</span>
                    </div>
                    <div>
                        <p class="text-caption font-label-bold uppercase text-on-surface-variant">Hotline 24/7</p>
                        <p class="text-body-lg font-bold">0987.654.321</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">verified</span>
                    </div>
                    <div>
                        <p class="text-caption font-label-bold uppercase text-on-surface-variant">Cam kết chất lượng</p>
                        <p class="text-body-lg font-bold">Bảo hành điện tử chính hãng</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="high-gloss-card p-lg rounded-2xl rim-light text-left">
            <form id="bookingForm" class="grid grid-cols-1 md:grid-cols-2 gap-md">
                <div class="space-y-2">
                    <label class="text-caption font-label-bold uppercase text-on-surface-variant">Họ tên</label>
                    <input name="CustomerName" required class="input-dark w-full px-4 py-3 rounded-lg text-white" placeholder="Nguyễn Văn A" type="text"/>
                </div>
                <div class="space-y-2">
                    <label class="text-caption font-label-bold uppercase text-on-surface-variant">Số điện thoại</label>
                    <input name="CustomerPhone" required class="input-dark w-full px-4 py-3 rounded-lg text-white" placeholder="0901 234 567" type="tel"/>
                </div>
                <div class="space-y-2">
                    <label class="text-caption font-label-bold uppercase text-on-surface-variant">Biển số xe</label>
                    <input name="Plate" class="input-dark w-full px-4 py-3 rounded-lg text-white" placeholder="51A-123.45" type="text"/>
                </div>
                <div class="space-y-2">
                    <label class="text-caption font-label-bold uppercase text-on-surface-variant">Thời gian</label>
                    <input name="AppointmentTime" required class="input-dark w-full px-4 py-3 rounded-lg text-white" type="datetime-local"/>
                </div>
                <div class="md:col-span-2 space-y-2">
                    <label class="text-caption font-label-bold uppercase text-on-surface-variant">Dịch vụ yêu cầu</label>
                    <select name="Services" class="input-dark w-full px-4 py-3 rounded-lg text-white bg-black">
                        @if (ViewBag.Services != null)
                        {
                            foreach (var s in (System.Collections.Generic.List<HP_Detailing.Models.Service>)ViewBag.Services)
                            {
                                <option value="@s.ServiceCode">@s.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="md:col-span-2 space-y-2">
                    <label class="text-caption font-label-bold uppercase text-on-surface-variant">Ghi chú thêm</label>
                    <textarea name="Note" class="input-dark w-full px-4 py-3 rounded-lg text-white resize-none" placeholder="Yêu cầu đặc biệt cho xế cưng của bạn..." rows="3"></textarea>
                </div>
                <div class="md:col-span-2 pt-4">
                    <button class="btn-primary w-full py-4 rounded-lg text-white font-label-bold text-label-bold uppercase tracking-widest flex justify-center items-center gap-2" type="submit">
                        <span>Gửi yêu cầu</span>
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </div>
                <div id="bookingMsg" class="md:col-span-2 mt-4 text-center font-bold"></div>
            </form>
        </div>
    </div>
</section>

