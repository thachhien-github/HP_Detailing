<!-- New Section: Pricing Tables -->
<section id="pricing" class="py-xl px-margin-mobile md:px-margin-desktop max-w-[1440px] mx-auto">
    <div class="text-center mb-lg">
        <h2 class="text-headline-md font-headline-md mb-2">Bảng giá dịch vụ</h2>
        <div class="w-24 h-1 bg-primary mx-auto mb-4"></div>
        <p class="text-body-lg text-on-surface-variant">Lựa chọn gói dịch vụ phù hợp nhất với nhu cầu và ngân sách của bạn.</p>
    </div>
    <div class="relative pt-8 px-4">
        <!-- Navigation Buttons -->
        <button id="prevPriceBtn" class="absolute left-0 top-[55%] -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-surface-container-high/80 hover:bg-primary/95 text-white flex items-center justify-center border border-outline-variant/30 hover:border-primary shadow-lg transition-all focus:outline-none select-none">
            <span class="material-symbols-outlined font-bold">chevron_left</span>
        </button>
        <button id="nextPriceBtn" class="absolute right-0 top-[55%] -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-surface-container-high/80 hover:bg-primary/95 text-white flex items-center justify-center border border-outline-variant/30 hover:border-primary shadow-lg transition-all focus:outline-none select-none">
            <span class="material-symbols-outlined font-bold">chevron_right</span>
        </button>

        <!-- Carousel Container -->
        <div id="pricingCarousel" class="flex flex-nowrap overflow-x-auto gap-8 items-stretch pb-12 pt-6 px-16 snap-x snap-mandatory scrollbar-none scroll-smooth">
            @{
                var servicesList = ViewBag.Services as List<HP_Detailing.Models.Service>;
                if (servicesList != null && servicesList.Any())
                {
                    var groupedServices = servicesList
                        .Where(s => s.ServiceCategory != null)
                        .GroupBy(s => s.ServiceCategory)
                        .OrderBy(g => g.Key.Id)
                        .ToList();

                    int catIndex = 0;
                    foreach (var group in groupedServices)
                    {
                        var category = group.Key;
                        var servicesInCat = group.OrderBy(s => s.UnitPrice).ToList();
                        var minPrice = servicesInCat.Any() ? servicesInCat.Min(s => s.UnitPrice) : 0;
                        bool isFeatured = catIndex == 1; // Mark the second category as featured/popular
                        catIndex++;

                        <div class="price-carousel-card transition-all duration-300 origin-center flex flex-col min-w-[280px] sm:min-w-[340px] md:min-w-[360px] snap-center @(isFeatured ? "featured" : "")">
                            @if (isFeatured)
                            {
                                <div class="high-gloss-card price-card featured p-lg rounded-2xl flex flex-col relative border border-primary/50 h-full flex-grow shadow-[0_15px_30px_rgba(255,86,37,0.15)]">
                                    <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-on-primary px-4 py-1 rounded-full text-caption font-bold uppercase tracking-widest whitespace-nowrap z-20">Phổ biến nhất</div>
                                    <h3 class="text-headline-sm font-headline-sm mb-2 text-primary">@category.Name</h3>
                                    <p class="text-body-md text-on-surface-variant mb-6">Giải pháp phục hồi và bảo vệ xe chuyên sâu.</p>
                                    <div class="text-display-lg-mobile font-display-lg text-white mb-8">
                                        <span class="text-body-lg font-bold">Từ</span> @((minPrice / 1000000.0m).ToString("0.#"))M <span class="text-caption">VNĐ</span>
                                    </div>
                                    <ul class="space-y-4 mb-10 flex-grow">
                                        @foreach (var svc in servicesInCat)
                                        {
                                            <li class="flex items-start justify-between gap-3 text-body-md border-b border-outline-variant/10 pb-2">
                                                <div class="flex items-start gap-2">
                                                    <span class="material-symbols-outlined text-primary mt-0.5">check_circle</span>
