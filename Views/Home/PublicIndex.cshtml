    <!-- Style and Carousel Script -->
    <style>
        /* Hide default scrollbars */
        .scrollbar-none::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-none {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* Prevent global Layout hover/scale conflicts inside the carousel */
        #pricingCarousel .high-gloss-card:hover {
            transform: none !important; /* disable translateY jump */
        }
        #pricingCarousel .price-card.featured {
            transform: none !important; /* disable double scaling */
        }

        /* Scale and highlight visual effects for carousel cards */
        .price-carousel-card {
            opacity: 0.6;
            transform: scale(0.9);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* When the user is NOT hovering the carousel, the JS determines the active center card */
        #pricingCarousel:not(:hover) .price-carousel-card.active-card {
            opacity: 1;
            transform: scale(1.05);
            z-index: 5;
        }

        /* When the user IS hovering the carousel, dim everything by default... */
        #pricingCarousel:hover .price-carousel-card {
            opacity: 0.5;
            transform: scale(0.9);
            z-index: 1;
        }

        /* ...and only highlight the EXACT card being hovered, stealing the spotlight */
        #pricingCarousel .price-carousel-card:hover {
            opacity: 1 !important;
            transform: scale(1.08) !important;
            z-index: 20 !important;
        }
        
        /* Soften inner card transition to match */
        .price-carousel-card .high-gloss-card {
            transition: border-color 0.4s, box-shadow 0.4s;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const carousel = document.getElementById('pricingCarousel');
            const prevBtn = document.getElementById('prevPriceBtn');
            const nextBtn = document.getElementById('nextPriceBtn');

            if (!carousel) return;

            function updateCardHighlight() {
                const cards = carousel.querySelectorAll('.price-carousel-card');
                if (cards.length === 0) return;

                const carouselRect = carousel.getBoundingClientRect();
                const carouselCenter = carouselRect.left + carouselRect.width / 2;

                let closestCard = null;
                let minDistance = Infinity;

                cards.forEach(card => {
                    const rect = card.getBoundingClientRect();
                    const cardCenter = rect.left + rect.width / 2;
                    const distance = Math.abs(carouselCenter - cardCenter);

                    if (distance < minDistance) {
                        minDistance = distance;
                        closestCard = card;
                    }
                });

                cards.forEach(card => {
                    if (card === closestCard) {
                        card.classList.add('active-card');
                    } else {
                        card.classList.remove('active-card');
                    }
                });
            }

            // Scroll action
            prevBtn.addEventListener('click', () => {
                const cards = carousel.querySelectorAll('.price-carousel-card');
                if (cards.length > 0) {
                    const cardWidth = cards[0].offsetWidth + 32; // card width + gap
                    carousel.scrollBy({ left: -cardWidth, behavior: 'smooth' });
                }
            });

            nextBtn.addEventListener('click', () => {
                const cards = carousel.querySelectorAll('.price-carousel-card');
                if (cards.length > 0) {
                    const cardWidth = cards[0].offsetWidth + 32; // card width + gap
                    carousel.scrollBy({ left: cardWidth, behavior: 'smooth' });
                }
            });

            // Update highlighting on scroll and resize
            carousel.addEventListener('scroll', updateCardHighlight);
            window.addEventListener('resize', updateCardHighlight);

            // Run initial check with a short delay for layout to settle
            setTimeout(updateCardHighlight, 300);
        });
    </script>
</section>

