@model List<HP_Detailing.Models.WarehouseStock>
@{ ViewData["Title"] = "Warehouse"; Layout = "_Layout";
   decimal totalStockValue = ViewBag.TotalStockValue ?? 0m;
   int lowStockCount = ViewBag.LowStockCount ?? 0;
   int outOfStockCount = ViewBag.OutOfStockCount ?? 0;
   var recentUsage = ViewBag.RecentUsage as List<HP_Detailing.Models.TicketMaterialUsage> ?? new();
}

<div class="p-4 sm:p-6 lg:p-8 space-y-8 flex-1 h-full min-h-0 overflow-y-auto">
    @await Html.PartialAsync("_PageHeader", new HP_Detailing.Models.PageHeaderModel {
        Title = "Quản lý Kho phụ tùng & Vật tư",
        Breadcrumbs = new System.Collections.Generic.List<HP_Detailing.Models.PageHeaderBreadcrumb> { new(){Label="Trang chủ",Path="/"}, new(){Label="Kho vật tư"} },
        ActionsSlotHtml = @"<button onclick=""HPUI.openModal('addMaterialModal')"" class=""flex items-center gap-2 px-4 py-2.5 bg-blue-500 text-slate-950 hover:opacity-90 transition-all text-xs font-bold uppercase tracking-widest rounded-lg shadow-[0_0_15px_rgba(59,130,246,0.2)]""><i data-lucide=""plus-square"" class=""w-5 h-5""></i> THÊM VẬT TƯ</button><a href=""/warehouse/imports/new"" class=""flex items-center gap-2 px-4 py-2.5 border border-blue-500/50 text-blue-400 hover:bg-blue-500/10 transition-all text-xs font-bold uppercase tracking-widest rounded-lg""><i data-lucide=""file-plus"" class=""w-5 h-5""></i> NHẬP KHO</a><a href=""/warehouse/imports"" class=""flex items-center gap-2 px-4 py-2.5 border border-slate-700 text-slate-300 hover:bg-slate-800 transition-all text-xs font-bold uppercase tracking-widest rounded-lg""><i data-lucide=""history"" class=""w-5 h-5""></i> LỊCH SỬ</a><a href=""/warehouse/audit"" class=""flex items-center gap-2 px-4 py-2.5 border border-emerald-500/50 text-emerald-400 hover:bg-emerald-500/10 transition-all text-xs font-bold uppercase tracking-widest rounded-lg""><i data-lucide=""clipboard-check"" class=""w-5 h-5""></i> KIỂM KÊ</a>"
    })

    @* KPI Stats *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-[#122131] border border-slate-800 p-6 rounded-xl relative overflow-hidden group hover:border-blue-500/30 transition-colors">
            <div class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity"><i data-lucide="banknote" class="w-20 h-20 text-blue-500"></i></div>
            <p class="text-slate-400 text-[11px] font-bold mb-3 uppercase tracking-widest">Tổng giá trị tồn kho</p>
            <h3 class="text-2xl font-bold text-blue-400 font-mono">@totalStockValue.ToString("N0") <span class="text-sm font-normal text-slate-400">VNĐ</span></h3>
            <p class="mt-3 text-[11px] text-slate-500">@Model.Count vật tư đang quản lý</p>
        </div>
        <div class="bg-[#122131] border @(lowStockCount > 0 ? "border-amber-500/30 shadow-[0_0_15px_rgba(245,158,11,0.08)]" : "border-slate-800") p-6 rounded-xl relative overflow-hidden group hover:border-amber-500/50 transition-colors">
            <div class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity"><i data-lucide="alert-triangle" class="w-20 h-20 text-amber-500"></i></div>
            <p class="text-slate-400 text-[11px] font-bold mb-3 uppercase tracking-widest">Cảnh báo tồn thấp</p>
            <h3 class="text-2xl font-bold @(lowStockCount > 0 ? "text-amber-500" : "text-slate-400") font-mono">@lowStockCount <span class="text-sm font-normal text-slate-400">Dưới định mức</span></h3>
            @if (outOfStockCount > 0) {
                <p class="mt-3 text-[11px] text-rose-400 font-bold">@outOfStockCount vật tư đã hết hoàn toàn!</p>
            } else { <p class="mt-3 text-[11px] text-slate-500">Tất cả trong ngưỡng an toàn</p> }
        </div>
        <div class="bg-[#122131] border border-slate-800 p-6 rounded-xl relative overflow-hidden group hover:border-emerald-500/30 transition-colors">
            <div class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity"><i data-lucide="package-check" class="w-20 h-20 text-emerald-500"></i></div>
            <p class="text-slate-400 text-[11px] font-bold mb-3 uppercase tracking-widest">Đang đủ hàng</p>
            <h3 class="text-2xl font-bold text-emerald-400 font-mono">@(Model.Count - lowStockCount - outOfStockCount) <span class="text-sm font-normal text-slate-400">Vật tư OK</span></h3>
            <p class="mt-3 text-[11px] text-slate-500">Cập nhật tức thời từ hệ thống</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        @* Inventory Table *@
        <div class="lg:col-span-8 xl:col-span-9">
            <div class="bg-[#122131] border border-slate-800 rounded-xl overflow-hidden shadow-sm">
                <div class="p-4 border-b border-slate-800 flex flex-col md:flex-row justify-between items-center bg-slate-900/30 gap-3">
                    @* Search *@
                    <div class="relative w-full md:w-56 group">
                        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 group-focus-within:text-blue-500 transition-colors"></i>
                        <input id="whSearch" type="text" placeholder="Tìm mã, tên vật tư..." class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg pl-10 pr-4 py-2 text-sm text-slate-200 outline-none focus:border-blue-500/50 transition-all placeholder:text-slate-600" />
                    </div>
                    @* Filter Tabs *@
                    <div class="flex gap-1 bg-[#0B101D] p-1 rounded-lg border border-slate-800 w-full md:w-auto">
                        <button onclick="whFilter('all')" id="f-all" class="wh-filter-btn flex-1 md:flex-none px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded transition-all text-blue-400 bg-slate-800">Tất cả</button>
                        <button onclick="whFilter('ok')"  id="f-ok"  class="wh-filter-btn flex-1 md:flex-none px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded transition-all text-slate-400 hover:text-slate-200">Còn hàng</button>
                        <button onclick="whFilter('low')" id="f-low" class="wh-filter-btn flex-1 md:flex-none px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded transition-all text-slate-400 hover:text-slate-200">Sắp hết</button>
                        <button onclick="whFilter('out')" id="f-out" class="wh-filter-btn flex-1 md:flex-none px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded transition-all text-slate-400 hover:text-slate-200">Hết hàng</button>
                    </div>
                    <span class="text-[10px] font-bold text-slate-500 uppercase whitespace-nowrap hidden lg:block">
                        <span id="whCount" class="text-blue-400">@Model.Count</span> vật tư
                    </span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left min-w-[640px]">
                        <thead><tr class="bg-[#1c2b3c]/30 border-b border-slate-800">
                            <th class="px-5 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Mã</th>
                            <th class="px-5 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Tên vật tư</th>
                            <th class="px-5 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-widest text-center">ĐVT</th>
                            <th class="px-5 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-widest text-center">Tồn / Định mức</th>
                            <th class="px-5 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-widest text-right">Đơn giá</th>
                            <th class="px-5 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Trạng thái</th>
                            <th class="px-5 py-4 w-10"></th>
                        </tr></thead>
                        <tbody id="whTableBody" class="divide-y divide-slate-800/50">
                            <tr><td colspan="7" class="px-5 py-16 text-center text-slate-500 text-sm">Đang tải dữ liệu...</td></tr>
                        </tbody>
                    </table>
                </div>
                @* Pagination *@
                <div id="whPagination" class="px-6 py-3 border-t border-slate-800 bg-[#1c2b3c]/20 flex justify-between items-center"></div>
            </div>
        </div>

        @* Usage Log — LIVE *@
        <div class="lg:col-span-4 xl:col-span-3">
            <div class="bg-[#122131] border border-slate-800 rounded-xl overflow-hidden flex flex-col shadow-sm">
                <div class="px-5 py-4 border-b border-slate-800 bg-[#1c2b3c]/50">
                    <h4 class="text-sm text-blue-400 flex items-center gap-2 font-bold"><i data-lucide="activity" class="w-4 h-4"></i> Nhật ký sử dụng gần đây</h4>
                </div>
                <div class="flex-1 overflow-y-auto p-4 space-y-4 max-h-[480px]">
                    @if (!recentUsage.Any()) {
                        <div class="text-center text-slate-500 text-sm py-10 space-y-2">
                            <i data-lucide="inbox" class="w-8 h-8 mx-auto text-slate-700"></i>
                            <p>Chưa có lịch sử sử dụng vật tư.</p>
                            <p class="text-xs">Sẽ cập nhật khi dịch vụ được hoàn thành.</p>
                        </div>
                    }
                    @foreach (var u in recentUsage) {
                        <div class="relative pl-5 border-l border-blue-500/20 pb-1">
                            <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-blue-500/60 ring-2 ring-[#122131]"></div>
                            <div class="flex justify-between items-start mb-0.5">
                                <span class="text-[10px] font-mono text-slate-500">
                                    <a href="/tickets/@u.TicketId" class="text-blue-400/70 hover:text-blue-400">@(u.Ticket?.TicketCode ?? $"#{u.TicketId}")</a>
                                </span>
                                <span class="text-[11px] font-bold text-rose-400 font-mono">-@u.Quantity.ToString("N2") @(u.Material?.Unit)</span>
                            </div>
                            <p class="text-xs font-bold text-slate-200 truncate">@(u.Material?.Name ?? "—")</p>
                            <p class="text-[10px] text-slate-500 mt-0.5">@(u.Ticket?.CustomerName ?? "—") · @(u.Ticket?.Plate ?? "—")</p>
                        </div>
                    }
                </div>
                <a href="/warehouse/imports" class="block w-full py-3.5 bg-[#1c2b3c] text-[10px] font-bold text-slate-400 hover:text-blue-400 hover:bg-[#273647] transition-all border-t border-slate-800 tracking-widest uppercase text-center">Xem lịch sử nhập kho</a>
            </div>
        </div>
    </div>
</div>

@* ===== Add Material Modal — Fixed Center ===== *@
<div id="addMaterialModal" class="fixed inset-0 z-[9999] hidden" style="display:none">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="HPUI.closeModal('addMaterialModal')"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
        <div class="bg-[#0F1923] border border-slate-700 rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden pointer-events-auto" onclick="event.stopPropagation()">
            <div class="px-6 py-5 border-b border-slate-800 flex justify-between items-center">
                <h2 class="text-lg font-bold text-white flex items-center gap-2"><i data-lucide="package-plus" class="w-5 h-5 text-blue-400"></i> Thêm Vật Tư Mới</h2>
                <button onclick="HPUI.closeModal('addMaterialModal')" class="text-slate-500 hover:text-white w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-800 transition"><i data-lucide="x" class="w-4 h-4"></i></button>
            </div>
            <div class="p-6 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Mã vật tư *</label>
                        <input type="text" id="newMatCode" placeholder="VD: CER-001" class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg py-2.5 px-4 text-sm text-slate-300 font-mono focus:border-blue-500 outline-none transition-all uppercase" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Tên vật tư *</label>
                        <input type="text" id="newMatName" placeholder="Tên đầy đủ..." class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg py-2.5 px-4 text-sm text-slate-300 focus:border-blue-500 outline-none transition-all" />
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Đơn vị tính</label>
                        <input type="text" id="newMatUnit" placeholder="Lọ, Cái, Lít..." class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg py-2.5 px-4 text-sm text-slate-300 focus:border-blue-500 outline-none transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Đơn giá (VNĐ)</label>
                        <input type="number" id="newMatPrice" placeholder="0" min="0" class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg py-2.5 px-4 text-sm text-blue-400 font-mono font-bold focus:border-blue-500 outline-none transition-all" />
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Định mức cảnh báo (Reorder Level)</label>
                    <input type="number" id="newMatReorder" placeholder="5" min="0" value="5" class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg py-2.5 px-4 text-sm text-slate-300 font-mono focus:border-blue-500 outline-none transition-all" />
                    <p class="text-[10px] text-slate-500">Khi tồn kho thấp hơn con số này sẽ hiện cảnh báo màu vàng.</p>
                </div>
            </div>
            <div class="p-5 border-t border-slate-800 bg-[#0B101D] flex justify-end gap-3">
                <button onclick="HPUI.closeModal('addMaterialModal')" class="px-5 py-2.5 text-sm font-bold text-slate-500 hover:text-white transition-colors">Hủy</button>
                <button id="btnSaveMaterial" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-lg transition-all flex items-center gap-2">
                    <i data-lucide="save" class="w-4 h-4"></i> Lưu vật tư
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function(){
    if (window.lucide) lucide.createIcons();

    // ── Table & Pagination (AJAX) ──
    var currentPage = 1;
    var pageSize = 5;
    var currentFilter = 'all';
    var searchTimer = null;

    function loadWarehouseList(page) {
        currentPage = page;
        var searchQ = document.getElementById('whSearch').value.trim();
        var params = `page=${currentPage}&pageSize=${pageSize}&status=${currentFilter}`;
        if (searchQ) params += `&search=${encodeURIComponent(searchQ)}`;

        fetch(`/warehouse/list?${params}`)
            .then(r => r.json())
            .then(data => {
                renderTable(data);
                renderPagination(data);
                var cEl = document.getElementById('whCount');
                if (cEl) cEl.textContent = data.totalCount;
            })
            .catch(() => {
                document.getElementById('whTableBody').innerHTML = '<tr><td colspan="7" class="px-5 py-16 text-center text-rose-400 text-sm">Lỗi tải dữ liệu</td></tr>';
            });
    }

    function renderTable(data) {
        var tbody = document.getElementById('whTableBody');
        if (!data.items || data.items.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="px-5 py-16 text-center text-slate-500 text-sm">Chưa có vật tư nào. <button onclick="HPUI.openModal(\'addMaterialModal\')" class="text-blue-400 hover:underline">Thêm ngay</button></td></tr>';
            return;
        }
        var html = '';
        data.items.forEach(function(s) {
            var isOut = s.status === 'out';
            var isLow = s.status === 'low';
            var rowClass = isOut ? "bg-rose-500/[0.03] hover:bg-rose-500/[0.06]" : isLow ? "bg-amber-500/[0.03] hover:bg-amber-500/[0.06]" : "hover:bg-slate-800/30";
            var badgeClass = isOut ? "bg-rose-500/10 text-rose-400 border-rose-500/20" : isLow ? "bg-amber-500/10 text-amber-500 border-amber-500/20" : "bg-emerald-500/10 text-emerald-400 border-emerald-500/20";
            var badgeText = isOut ? "Hết hàng" : isLow ? "Sắp hết" : "Còn hàng";
            var qtyClass = isOut ? "text-rose-400" : isLow ? "text-amber-400" : "text-slate-200";
            var idClass = isOut ? "text-rose-400" : isLow ? "text-amber-400" : "text-blue-400";
            var alertIcon = (isLow || isOut) ? `<i data-lucide="alert-triangle" class="w-3.5 h-3.5 inline mr-0.5 ${isOut ? 'text-rose-400' : 'text-amber-400'}"></i>` : '';
            
            html += `<tr class="${rowClass} transition-colors cursor-pointer" onclick="HPUI.loadPage('/warehouse/materials/${s.materialId}')">
                <td class="px-5 py-4 font-mono text-xs font-bold ${idClass}">${s.materialCode}</td>
                <td class="px-5 py-4 font-bold text-sm text-slate-200">${s.name}</td>
                <td class="px-5 py-4 text-center text-xs text-slate-400">${s.unit}</td>
                <td class="px-5 py-4 text-center font-bold font-mono ${qtyClass}">
                    ${alertIcon}
                    ${s.quantityOnHand.toLocaleString('vi-VN')} <span class="text-[10px] text-slate-500 font-normal">/ ${s.reorderLevel.toLocaleString('vi-VN')}</span>
                </td>
                <td class="px-5 py-4 text-right font-mono text-xs text-slate-400">${s.unitPrice.toLocaleString('vi-VN')}</td>
                <td class="px-5 py-4"><span class="px-2.5 py-1 rounded text-[10px] font-bold border uppercase tracking-widest ${badgeClass}">${badgeText}</span></td>
                <td class="px-5 py-4 text-center" onclick="event.stopPropagation()">
                    <a href="/warehouse/materials/${s.materialId}" class="text-slate-500 hover:text-blue-400 transition-colors"><i data-lucide="external-link" class="w-4 h-4"></i></a>
                </td>
            </tr>`;
        });
        tbody.innerHTML = html;
        if (window.lucide) lucide.createIcons();
    }

    function renderPagination(data) {
        var el = document.getElementById('whPagination');
        var totalPages = Math.ceil(data.totalCount / data.pageSize);
        if (totalPages <= 1) {
            el.innerHTML = '';
            return;
        }
        var btns = '';
        btns += `<button onclick="loadWarehouseList(${data.page - 1})" ${data.page <= 1 ? 'disabled' : ''} class="px-3 py-1.5 rounded text-xs font-bold ${data.page <= 1 ? 'text-slate-600 cursor-not-allowed' : 'text-slate-300 hover:bg-slate-700'}"><i data-lucide="chevron-left" class="w-4 h-4 inline"></i> Trước</button>`;
        for (var i = 1; i <= totalPages; i++) {
            if (i === data.page) {
                btns += `<button class="px-3 py-1.5 rounded text-xs font-bold bg-blue-600 text-white">${i}</button>`;
            } else if (Math.abs(i - data.page) <= 2 || i === 1 || i === totalPages) {
                btns += `<button onclick="loadWarehouseList(${i})" class="px-3 py-1.5 rounded text-xs font-bold text-slate-400 hover:bg-slate-700 hover:text-white">${i}</button>`;
            } else if (Math.abs(i - data.page) === 3) {
                btns += `<span class="px-1 text-slate-600">…</span>`;
            }
        }
        btns += `<button onclick="loadWarehouseList(${data.page + 1})" ${data.page >= totalPages ? 'disabled' : ''} class="px-3 py-1.5 rounded text-xs font-bold ${data.page >= totalPages ? 'text-slate-600 cursor-not-allowed' : 'text-slate-300 hover:bg-slate-700'}">Sau <i data-lucide="chevron-right" class="w-4 h-4 inline"></i></button>`;

        el.innerHTML = `<span class="text-[11px] text-slate-500 font-bold uppercase tracking-widest">Trang <span class="text-blue-400">${data.page}</span> / ${totalPages}</span><div class="flex items-center gap-1">${btns}</div>`;
        if (window.lucide) lucide.createIcons();
    }

    window.loadWarehouseList = loadWarehouseList;

    window.whFilter = function(f) {
        currentFilter = f;
        document.querySelectorAll('.wh-filter-btn').forEach(b => {
            b.className = 'wh-filter-btn flex-1 md:flex-none px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded transition-all text-slate-400 hover:text-slate-200';
        });
        var active = document.getElementById('f-' + f);
        if (active) active.className = 'wh-filter-btn flex-1 md:flex-none px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded transition-all text-blue-400 bg-slate-800';
        loadWarehouseList(1);
    };

    var searchEl = document.getElementById('whSearch');
    if (searchEl) {
        searchEl.addEventListener('input', function() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => loadWarehouseList(1), 300);
        });
    }

    // Tải dữ liệu trang đầu
    loadWarehouseList(1);

    // ── Add Material ──
    var btnSave = document.getElementById('btnSaveMaterial');
    if (btnSave && !btnSave.dataset.init) {
        btnSave.dataset.init = '1';
        btnSave.addEventListener('click', function() {
            var code    = (document.getElementById('newMatCode').value || '').trim();
            var name    = (document.getElementById('newMatName').value || '').trim();
            var unit    = (document.getElementById('newMatUnit').value || '').trim();
            var price   = parseFloat(document.getElementById('newMatPrice').value) || 0;
            var reorder = parseFloat(document.getElementById('newMatReorder').value) || 5;
            if (!code || !name) { HPUI.toast('Mã và Tên vật tư là bắt buộc!', 'warning'); return; }
            btnSave.disabled = true;
            btnSave.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Đang lưu...';
            lucide.createIcons();
            fetch('/warehouse/materials/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ MaterialCode: code, Name: name, Unit: unit, UnitPrice: price, ReorderLevel: reorder })
            }).then(r => r.json()).then(data => {
                if (data.success) {
                    HPUI.toast('Đã thêm vật tư thành công!', 'success');
                    HPUI.closeModal('addMaterialModal');
                    setTimeout(() => HPUI.loadPage('/warehouse'), 400);
                } else {
                    btnSave.disabled = false;
                    btnSave.innerHTML = '<i data-lucide="save" class="w-4 h-4"></i> Lưu vật tư';
                    lucide.createIcons();
                    HPUI.toast(data.message || 'Có lỗi xảy ra!', 'error');
                }
            }).catch(() => {
                btnSave.disabled = false;
                btnSave.innerHTML = '<i data-lucide="save" class="w-4 h-4"></i> Lưu vật tư';
                lucide.createIcons();
                HPUI.toast('Lỗi kết nối!', 'error');
            });
        });
    }
})();
</script>
