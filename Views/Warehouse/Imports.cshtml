@{ ViewData["Title"] = "Lịch sử nhập kho"; Layout = "_Layout"; }

<div class="p-4 sm:p-6 lg:p-8 space-y-8 flex-1 h-full min-h-0 overflow-y-auto">
    @await Html.PartialAsync("_PageHeader", new HP_Detailing.Models.PageHeaderModel {
        Title = "Lịch sử nhập kho",
        Breadcrumbs = new System.Collections.Generic.List<HP_Detailing.Models.PageHeaderBreadcrumb> {
            new(){Label="Trang chủ",Path="/"}, new(){Label="Kho vật tư",Path="/warehouse"}, new(){Label="Lịch sử nhập kho"}
        },
        ActionsSlotHtml = @"<a href=""/warehouse/imports/new"" class=""flex items-center gap-2 px-4 py-2.5 bg-blue-500 text-slate-950 hover:opacity-90 transition-all text-xs font-bold uppercase tracking-widest rounded-lg""><i data-lucide=""plus"" class=""w-5 h-5""></i> TẠO PHIẾU NHẬP</a>"
    })

    @* Date Range & Export Report Panel *@
    <div class="bg-[#122131] border border-slate-800 rounded-xl p-5 shadow-sm">
        <div class="flex flex-col md:flex-row items-end justify-between gap-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 flex-1 w-full">
                <div class="space-y-1.5">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Từ ngày</label>
                    <div class="relative">
                        <i data-lucide="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500"></i>
                        <input type="date" id="repStartDate" class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg pl-10 pr-4 py-2 text-sm text-slate-300 focus:border-blue-500 outline-none transition-all" />
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Đến ngày</label>
                    <div class="relative">
                        <i data-lucide="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500"></i>
                        <input type="date" id="repEndDate" class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg pl-10 pr-4 py-2 text-sm text-slate-300 focus:border-blue-500 outline-none transition-all" />
                    </div>
                </div>
            </div>
            <div class="flex gap-3 w-full md:w-auto">
                <button onclick="filterImports()" class="flex-1 md:flex-none px-5 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white rounded-lg text-sm font-bold flex items-center justify-center gap-2 transition-all">
                    <i data-lucide="filter" class="w-4 h-4"></i> Lọc
                </button>
                <button onclick="clearFilter()" class="flex-1 md:flex-none px-5 py-2.5 bg-slate-800/50 hover:bg-slate-700 text-slate-400 hover:text-white rounded-lg text-sm font-bold flex items-center justify-center gap-2 transition-all">
                    <i data-lucide="x" class="w-4 h-4"></i> Xóa lọc
                </button>
                <button onclick="exportDetailedReport()" class="flex-1 md:flex-none px-5 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-bold flex items-center justify-center gap-2 transition-all shadow-lg shadow-emerald-600/20">
                    <i data-lucide="download" class="w-4 h-4"></i> Xuất CSV
                </button>
            </div>
        </div>
    </div>

    <div class="bg-[#122131] border border-slate-800 rounded-xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap min-w-[800px]">
                <thead>
                    <tr class="bg-[#1c2b3c]/50 border-b border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">Mã phiếu</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">Thời gian</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">Nhà cung cấp</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">Người lập</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">Số mặt hàng</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest text-right">Tổng tiền</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="importsTableBody" class="divide-y divide-slate-800 bg-[#122131]">
                    <tr><td colspan="7" class="px-6 py-16 text-center text-slate-500 text-sm">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
        @* Footer tổng hợp — lấy từ summary toàn filter, KHÔNG theo page *@
        <div id="importsFooter" class="px-6 py-4 border-t border-slate-800 bg-[#1c2b3c]/30 flex justify-between items-center text-[11px] text-slate-500 font-bold uppercase tracking-widest">
        </div>
        @* Pagination *@
        <div id="importsPagination" class="px-6 py-3 border-t border-slate-800 bg-[#1c2b3c]/20 flex justify-between items-center"></div>
    </div>
</div>

<script>
(function(){
    if (window.lucide) lucide.createIcons();

    var currentPage = 1;
    var pageSize = 5;

    function getFilterParams() {
        var start = document.getElementById('repStartDate').value;
        var end = document.getElementById('repEndDate').value;
        var params = `page=${currentPage}&pageSize=${pageSize}`;
        if (start) params += `&startDate=${start}`;
        if (end) params += `&endDate=${end}`;
        return params;
    }

    function loadImports(page) {
        currentPage = page;
        var params = getFilterParams();

        fetch(`/warehouse/imports/list?${params}`)
            .then(r => r.json())
            .then(data => {
                renderTable(data);
                renderFooter(data);
                renderPagination(data);
            })
            .catch(() => {
                document.getElementById('importsTableBody').innerHTML =
                    '<tr><td colspan="7" class="px-6 py-16 text-center text-rose-400 text-sm">Lỗi tải dữ liệu</td></tr>';
            });
    }

    function renderTable(data) {
        var tbody = document.getElementById('importsTableBody');
        if (!data.items || data.items.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="px-6 py-16 text-center text-slate-500 text-sm">Chưa có phiếu nhập kho nào khớp với bộ lọc. <a href="/warehouse/imports/new" class="text-blue-400 hover:underline">Tạo phiếu nhập mới</a></td></tr>';
            return;
        }
        var html = '';
        data.items.forEach(function(imp) {
            var statusClass = imp.status === 'Hoàn tất'
                ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'
                : 'bg-amber-500/10 text-amber-400 border-amber-500/20';
            var statusIcon = imp.status === 'Hoàn tất' ? 'check-circle' : 'clock';
            html += `<tr class="hover:bg-slate-800/30 transition-colors cursor-pointer group" onclick="HPUI.loadPage('/warehouse/imports/${imp.id}')">
                <td class="px-6 py-4"><div class="flex items-center gap-2"><i data-lucide="file-text" class="w-4 h-4 text-blue-400"></i><span class="font-mono text-sm font-bold text-blue-400 group-hover:underline">${imp.importCode}</span></div></td>
                <td class="px-6 py-4 text-sm text-slate-300 font-mono">${imp.importDate}</td>
                <td class="px-6 py-4 text-sm font-bold text-slate-200">${imp.supplierName}</td>
                <td class="px-6 py-4 text-sm text-slate-400">${imp.createdBy}</td>
                <td class="px-6 py-4 text-center"><span class="inline-flex items-center gap-1 px-2 py-0.5 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 rounded font-bold text-xs">${imp.itemCount} <i data-lucide="package" class="w-3 h-3"></i></span></td>
                <td class="px-6 py-4 text-right text-sm font-mono font-bold text-emerald-400">${Number(imp.totalAmount).toLocaleString('vi-VN')}<span class="text-slate-500 font-normal">đ</span></td>
                <td class="px-6 py-4"><span class="inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-widest px-2.5 py-1 rounded border ${statusClass}"><i data-lucide="${statusIcon}" class="w-3.5 h-3.5"></i>${imp.status}</span></td>
            </tr>`;
        });
        tbody.innerHTML = html;
        if (window.lucide) lucide.createIcons();
    }

    function renderFooter(data) {
        var el = document.getElementById('importsFooter');
        if (!data.summary || data.summary.totalReceipts === 0) {
            el.innerHTML = '';
            return;
        }
        // Footer lấy từ summary — tính trên TOÀN BỘ filter, không theo page
        el.innerHTML = `<span>Tổng: <span class="text-blue-400">${data.summary.totalReceipts}</span> phiếu nhập</span>
            <span>Tổng giá trị: <span class="text-emerald-400 font-mono">${Number(data.summary.totalValue).toLocaleString('vi-VN')}đ</span></span>`;
    }

    function renderPagination(data) {
        var el = document.getElementById('importsPagination');
        var totalPages = Math.ceil(data.totalCount / data.pageSize);
        if (totalPages <= 1) {
            el.innerHTML = '';
            return;
        }
        var btns = '';
        // Nút Previous
        btns += `<button onclick="loadImportsPage(${data.page - 1})" ${data.page <= 1 ? 'disabled' : ''} class="px-3 py-1.5 rounded text-xs font-bold ${data.page <= 1 ? 'text-slate-600 cursor-not-allowed' : 'text-slate-300 hover:bg-slate-700 transition-colors'}"><i data-lucide="chevron-left" class="w-4 h-4 inline"></i> Trước</button>`;
        // Số trang
        for (var i = 1; i <= totalPages; i++) {
            if (i === data.page) {
                btns += `<button class="px-3 py-1.5 rounded text-xs font-bold bg-blue-600 text-white">${i}</button>`;
            } else if (Math.abs(i - data.page) <= 2 || i === 1 || i === totalPages) {
                btns += `<button onclick="loadImportsPage(${i})" class="px-3 py-1.5 rounded text-xs font-bold text-slate-400 hover:bg-slate-700 hover:text-white transition-colors">${i}</button>`;
            } else if (Math.abs(i - data.page) === 3) {
                btns += `<span class="px-1 text-slate-600">…</span>`;
            }
        }
        // Nút Next
        btns += `<button onclick="loadImportsPage(${data.page + 1})" ${data.page >= totalPages ? 'disabled' : ''} class="px-3 py-1.5 rounded text-xs font-bold ${data.page >= totalPages ? 'text-slate-600 cursor-not-allowed' : 'text-slate-300 hover:bg-slate-700 transition-colors'}">Sau <i data-lucide="chevron-right" class="w-4 h-4 inline"></i></button>`;

        el.innerHTML = `<span class="text-[11px] text-slate-500 font-bold uppercase tracking-widest">Trang <span class="text-blue-400">${data.page}</span> / ${totalPages}</span><div class="flex items-center gap-1">${btns}</div>`;
        if (window.lucide) lucide.createIcons();
    }

    // Hàm global cho pagination
    window.loadImportsPage = function(p) { loadImports(p); };

    // Lọc theo ngày — luôn reset về trang 1
    window.filterImports = function() {
        loadImports(1);
    };

    // Xóa lọc
    window.clearFilter = function() {
        document.getElementById('repStartDate').value = '';
        document.getElementById('repEndDate').value = '';
        loadImports(1);
    };

    // Xuất CSV (giữ nguyên chức năng cũ)
    window.exportDetailedReport = function() {
        var start = document.getElementById('repStartDate').value;
        var end = document.getElementById('repEndDate').value;
        window.open(`/warehouse/imports/export-report?startDate=${start}&endDate=${end}`, '_blank');
    };

    // Khởi tải lần đầu
    loadImports(1);
})();
</script>
