@model IEnumerable<HP_Detailing.Models.WarehouseStock>
@{ ViewData["Title"] = "Warehouse Audit"; Layout = "_Layout"; }
<div class="p-4 sm:p-6 lg:p-10 max-w-[1600px] mx-auto space-y-8 flex-1">
    @await Html.PartialAsync("_PageHeader", new HP_Detailing.Models.PageHeaderModel {
        Title = "Kiểm kê kho định kỳ",
        Breadcrumbs = new System.Collections.Generic.List<HP_Detailing.Models.PageHeaderBreadcrumb> { 
            new(){Label="Trang chủ",Path="/"}, 
            new(){Label="Kho vật tư",Path="/warehouse"}, 
            new(){Label="Phiếu kiểm kê"} 
        },
        ActionsSlotHtml = @"<a href=""/warehouse/audit/history-page"" class=""flex items-center gap-2 px-4 py-2.5 border border-slate-700 text-slate-300 hover:bg-slate-800 transition-all text-xs font-bold uppercase tracking-widest rounded-lg""><i data-lucide=""history"" class=""w-5 h-5""></i> LỊCH SỬ KIỂM KÊ</a><button onclick=""HPUI.saveAudit()"" class=""flex items-center gap-2 px-6 py-2.5 bg-emerald-600 text-white hover:bg-emerald-500 transition-all text-xs font-bold uppercase tracking-widest rounded-lg shadow-[0_0_15px_rgba(16,185,129,0.3)]""><i data-lucide=""save"" class=""w-5 h-5""></i> LƯU PHIẾU KIỂM KÊ</button>"
    })

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        @* Sidebar: Filter & Summary *@
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-[#122131] border border-slate-800 rounded-xl p-6 shadow-sm">
                <h3 class="text-sm font-bold text-slate-300 uppercase tracking-widest mb-6">Bộ lọc kiểm kê</h3>
                <div class="space-y-4">
                    <div>
                        <input id="auditSearch" type="text" placeholder="Tìm tên, mã vật tư..." onkeyup="HPUI.filterAudit()" class="w-full bg-[#051424] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-blue-500 outline-none" />
                    </div>
                </div>
            </div>

            <div class="bg-[#122131] border border-slate-800 rounded-xl p-6 shadow-sm">
                <h3 class="text-sm font-bold text-slate-300 uppercase tracking-widest mb-6">Tổng quan kiểm kê</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-xs text-slate-500">Tổng mặt hàng</span>
                        <span class="text-sm font-bold text-slate-200">@Model.Count()</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-xs text-slate-500 text-rose-500/80">Chênh lệch</span>
                        <span id="auditDiscrepancyCount" class="text-sm font-bold text-rose-500">0</span>
                    </div>
                </div>
            </div>
        </div>

        @* Main: Audit Table *@
        <div class="lg:col-span-3">
            <div class="bg-[#122131] border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse" id="auditTable">
                        <thead>
                            <tr class="bg-slate-900/50 border-b border-slate-800">
                                <th class="p-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Sản phẩm</th>
                                <th class="p-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Đơn vị</th>
                                <th class="p-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Tồn kho</th>
                                <th class="p-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Thực tế</th>
                                <th class="p-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Chênh lệch</th>
                                <th class="p-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800/50">
                            @foreach (var stock in Model)
                            {
                                var mat = stock.Material;
                                var matName = mat?.Name ?? "";
                                var matCode = mat?.MaterialCode ?? "";
                                var unit = mat?.Unit ?? "";
                                var qty = stock.QuantityOnHand;

                                <tr class="audit-row hover:bg-slate-800/20 transition-colors group" data-name="@matName.ToLower()" data-code="@matCode.ToLower()">
                                    <td class="p-5">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center text-blue-500">
                                                <i data-lucide="package" class="w-5 h-5"></i>
                                            </div>
                                            <div>
                                                <div class="text-sm font-bold text-slate-200">@matName</div>
                                                <div class="text-[10px] text-slate-500 font-mono mt-0.5">@matCode</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-5 text-center text-xs text-slate-400">@unit</td>
                                    <td class="p-5 text-center font-mono text-sm text-slate-300">@qty.ToString("0.##")</td>
                                    <td class="p-5 text-center">
                                        <input type="number" step="0.01" data-material-id="@(mat?.Id)" data-original-qty="@qty" value="@qty.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" oninput="HPUI.calcDiscrepancy(this)" class="audit-actual-qty w-20 bg-[#051424] border border-slate-800 rounded px-2 py-1 text-center text-sm text-blue-400 font-bold focus:border-blue-500 outline-none" />
                                    </td>
                                    <td class="p-5 text-center">
                                        <span class="discrepancy-badge text-xs font-bold text-slate-500" data-has-diff="false">0</span>
                                    </td>
                                    <td class="p-5">
                                        <input type="text" placeholder="..." class="audit-note w-full bg-transparent border-none text-xs text-slate-400 focus:ring-0 outline-none italic" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
            <div class="mt-6 flex justify-end">
                <p class="text-[11px] text-slate-500 italic">* Hệ thống sẽ tự động cập nhật cân bằng kho sau khi lưu phiếu kiểm kê này.</p>
            </div>
        </div>
    </div>

    <script>
        (function(){
            window.HPUI = window.HPUI || {};
            
            HPUI.calcDiscrepancy = function(input) {
                var actual = parseFloat(input.value);
                if (isNaN(actual)) actual = 0;
                
                var original = parseFloat(input.getAttribute('data-original-qty'));
                var diff = actual - original;
                var badge = input.closest('tr').querySelector('.discrepancy-badge');
                
                if (Math.abs(diff) < 0.001) {
                    badge.className = 'discrepancy-badge text-xs font-bold text-slate-500';
                    badge.textContent = '0';
                    badge.style.background = 'none';
                    badge.style.border = 'none';
                    badge.setAttribute('data-has-diff', 'false');
                } else if (diff > 0) {
                    badge.className = 'discrepancy-badge text-xs font-bold text-emerald-500 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20';
                    badge.textContent = '+' + diff.toFixed(2).replace(/\.00$/, '');
                    badge.setAttribute('data-has-diff', 'true');
                } else {
                    badge.className = 'discrepancy-badge text-xs font-bold text-rose-500 bg-rose-500/10 px-2 py-0.5 rounded border border-rose-500/20';
                    badge.textContent = diff.toFixed(2).replace(/\.00$/, '');
                    badge.setAttribute('data-has-diff', 'true');
                }

                // Update total discrepancy count
                var diffCount = document.querySelectorAll('.discrepancy-badge[data-has-diff="true"]').length;
                var countEl = document.getElementById('auditDiscrepancyCount');
                if (countEl) countEl.textContent = diffCount;
            };

            HPUI.filterAudit = function() {
                var q = (document.getElementById('auditSearch').value || '').toLowerCase().trim();
                var rows = document.querySelectorAll('.audit-row');
                rows.forEach(function(row) {
                    var name = row.getAttribute('data-name') || '';
                    var code = row.getAttribute('data-code') || '';
                    if (!q || name.includes(q) || code.includes(q)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            };

            HPUI.saveAudit = function() {
                var rows = document.querySelectorAll('.audit-row');
                var items = [];
                var hasDiff = false;

                // Gửi TẤT CẢ vật tư để tạo snapshot đầy đủ
                rows.forEach(function(row) {
                    var inputQty = row.querySelector('.audit-actual-qty');
                    var inputNote = row.querySelector('.audit-note');
                    var badge = row.querySelector('.discrepancy-badge');
                    
                    var matId = parseInt(inputQty.getAttribute('data-material-id'));
                    var actualQty = parseFloat(inputQty.value) || 0;
                    var note = inputNote ? inputNote.value.trim() : '';

                    if (badge && badge.getAttribute('data-has-diff') === 'true') hasDiff = true;

                    items.push({
                        MaterialId: matId,
                        ActualQuantity: actualQty,
                        Note: note
                    });
                });

                if (items.length === 0) {
                    HPUI.toast('Không có dữ liệu kiểm kê!', 'warning');
                    return;
                }

                if (!hasDiff) {
                    if (!confirm('Không có chênh lệch nào. Vẫn muốn lưu phiếu kiểm kê?')) return;
                }

                HPUI.toast('Đang lưu phiếu kiểm kê...', 'info');

                fetch('/warehouse/audit/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ Items: items })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        HPUI.toast(data.message, 'success');
                        setTimeout(function(){
                            if (window.HPUI && window.HPUI.loadPage) {
                                window.HPUI.loadPage('/warehouse');
                            } else {
                                window.location.reload();
                            }
                        }, 1000);
                    } else {
                        HPUI.toast(data.message, 'error');
                    }
                })
                .catch(err => {
                    console.error(err);
                    HPUI.toast('Lỗi kết nối khi lưu kiểm kê!', 'error');
                });
            };
        })();
    </script>
</div>
