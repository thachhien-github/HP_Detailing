@model HP_Detailing.Models.ViewModels.CarIndexViewModel
@{ ViewData["Title"] = "Cars"; Layout = "_Layout"; }

<div class="p-4 sm:p-6 lg:p-8 space-y-8">
    @await Html.PartialAsync("_PageHeader", new HP_Detailing.Models.PageHeaderModel
    {
        Title = "Hồ sơ phương tiện (Xe)",
        Breadcrumbs = new System.Collections.Generic.List<HP_Detailing.Models.PageHeaderBreadcrumb>
        {
            new() { Label = "Trang chủ", Path = "/" },
            new() { Label = "Quản lý phương tiện" }
        },
        ActionsSlotHtml = @"<button onclick=""HPUI.toast('Đang trích xuất dữ liệu phương tiện...','info')"" class=""px-6 py-2.5 border border-slate-700 text-slate-300 hover:bg-slate-800 transition-all text-sm rounded-lg flex items-center gap-2""><i data-lucide=""upload"" class=""w-4 h-4""></i> Xuất dữ liệu</button><button onclick=""HPUI.toast('Chức năng thêm xe đang phát triển...','info')"" class=""px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)] text-sm rounded-lg flex items-center gap-2""><i data-lucide=""plus"" class=""w-4 h-4""></i> Thêm phương tiện</button>"
    })

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8 items-start">
        @* Left: Table *@
        <div class="xl:col-span-7 bg-[#122131] border border-slate-800 rounded-xl overflow-hidden shadow-sm">
            @* Integrated Filter Bar *@
            <div class="p-4 border-b border-slate-800 flex flex-col md:flex-row md:items-center justify-between gap-4 bg-slate-900/30">
                <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
                    <div class="relative w-full sm:w-64 group">
                        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 group-focus-within:text-blue-500 transition-colors"></i>
                        <input type="text" id="carSearch" placeholder="Biển số, khách..." class="w-full bg-[#0B101D] border border-slate-700/50 rounded-lg pl-10 pr-4 py-2 text-sm text-slate-200 outline-none focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/5 transition-all placeholder:text-slate-600" />
                    </div>
                </div>
                <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest hidden lg:block">
                    <span class="text-blue-400">@Model.Cars.Count</span> xe
                </div>
            </div>
            <div class="overflow-x-auto h-[600px] custom-scrollbar relative">
                <table class="w-full text-left border-collapse">
                    <thead class="sticky top-0 bg-[#122131] z-10 shadow-sm border-b border-slate-800">
                        <tr>
                            <th class="px-6 py-3 text-[12px] font-semibold text-slate-500 uppercase tracking-widest">Biển số</th>
                            <th class="px-6 py-3 text-[12px] font-semibold text-slate-500 uppercase tracking-widest">Thông tin xe</th>
                            <th class="px-6 py-3 text-[12px] font-semibold text-slate-500 uppercase tracking-widest">Người liên hệ</th>
                            <th class="px-6 py-3 text-[12px] font-semibold text-slate-500 uppercase tracking-widest">Lần cuối ghé</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800" id="carTableBody">
                        @if (Model.Cars.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-slate-500 text-sm">Chưa có dữ liệu xe nào.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var car in Model.Cars)
                            {
                                var searchTerms = $"{car.Plate} {car.CustomerName} {car.CarModel} {car.Brand} {car.Model}".ToLower();
                                <tr class="cursor-pointer hover:bg-slate-800/50 border-l-2 border-l-transparent transition-colors car-row" data-search="@searchTerms" onclick="loadCarDetails('@car.Plate', this)">
                                    <td class="px-6 py-4 font-mono text-[14px] font-bold text-blue-400 whitespace-nowrap">@car.Plate</td>
                                    <td class="px-6 py-4">
                                        <p class="text-sm font-bold text-slate-200 line-clamp-1">@car.CarModel</p>
                                    </td>
                                    <td class="px-6 py-4">
                                        <p class="text-[13px] font-medium text-slate-300">@car.CustomerName</p>
                                        <p class="text-[11px] text-slate-500 font-mono">@car.CustomerPhone</p>
                                    </td>
                                    <td class="px-6 py-4 text-[12px] text-slate-400">@car.LastVisit.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Right: Detail Panel *@
        <div class="xl:col-span-5 space-y-6 hidden" id="carDetailPanel">
            <div class="bg-[#122131] border border-slate-800 rounded-xl overflow-hidden shadow-[0_0_15px_rgba(173,199,255,0.05)]">
                <div class="p-6 bg-gradient-to-br from-slate-900 to-slate-950 border-b border-slate-800 relative">
                    <div class="absolute top-4 right-4 flex gap-2">
                        <button class="text-slate-500 hover:text-red-400 transition-colors p-2"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    </div>
                    <div class="flex flex-col items-center gap-4 text-center">
                        <div class="w-20 h-20 bg-slate-900 rounded-full flex items-center justify-center border-4 border-slate-800 shadow-xl">
                            <i data-lucide="car" class="w-10 h-10 text-blue-400"></i>
                        </div>
                        <div>
                            <h4 id="detailPlate" class="text-2xl font-bold font-mono text-blue-400 tracking-wider bg-blue-500/10 border border-blue-500/20 px-4 py-1.5 rounded-lg inline-block">...</h4>
                            <p id="detailBrand" class="mt-3 text-sm font-bold text-slate-200 line-clamp-1">...</p>
                        </div>
                    </div>
                    <div class="mt-8 grid grid-cols-2 gap-y-6 gap-x-8">
                        <div class="space-y-1">
                            <p class="text-[10px] text-slate-500 uppercase font-bold flex items-center gap-1.5"><i data-lucide="user" class="w-3 h-3"></i> Người liên hệ</p>
                            <p id="detailContact" class="text-[13px] font-medium text-slate-200">...</p>
                        </div>
                        <div class="space-y-1 text-right">
                            <p class="text-[10px] text-slate-500 uppercase font-bold flex justify-end items-center gap-1.5">SĐT <i data-lucide="phone" class="w-3 h-3"></i></p>
                            <p id="detailPhone" class="text-[13px] font-mono font-medium text-slate-200">...</p>
                        </div>
                    </div>
                </div>

                @* Service history *@
                <div class="bg-[#122131]">
                    <div class="flex border-b border-slate-800">
                        <button class="flex-1 py-4 text-sm font-bold border-b-2 text-blue-400 border-blue-500 bg-slate-900/50">Lịch sử Phiếu Dịch Vụ</button>
                    </div>
                    <div class="p-4 space-y-4" id="historyContainer">
                        <!-- Lịch sử được đổ bằng JS -->
                    </div>
                    <div class="p-4 pt-0">
                        <button onclick="createNewTicket()" class="w-full py-3 border border-dashed border-slate-700 rounded-lg text-slate-500 hover:text-blue-400 hover:border-blue-500/50 transition-all flex items-center justify-center gap-2 text-xs font-bold uppercase tracking-widest mt-2">
                            <i data-lucide="plus" class="w-4 h-4"></i> Tạo phiếu dịch vụ mới cho xe này
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="xl:col-span-5 space-y-6" id="carEmptyState">
            <div class="h-full min-h-[400px] border-2 border-dashed border-slate-800 rounded-xl flex flex-col items-center justify-center text-slate-500">
                <i data-lucide="car" class="w-12 h-12 mb-4 text-slate-700"></i>
                <p class="text-sm">Chọn một xe bên danh sách để xem chi tiết</p>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        if (window.lucide) lucide.createIcons();

        // Lọc tìm kiếm xe
        var searchInput = document.getElementById('carSearch');
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                var query = this.value.toLowerCase().trim();
                document.querySelectorAll('#carTableBody .car-row').forEach(function(row) {
                    var text = row.getAttribute('data-search') || '';
                    row.style.display = text.includes(query) ? '' : 'none';
                });
            });
        }

        // Biến lưu biển số đang chọn để dùng cho việc tạo phiếu mới
        window.currentSelectedPlate = '';

        // Hàm gọi API lấy chi tiết xe
        window.loadCarDetails = function(plate, rowElement) {
            // Xóa active class của tất cả các dòng
            document.querySelectorAll('.car-row').forEach(r => {
                r.classList.remove('bg-blue-500/10', 'border-l-blue-500');
                r.classList.add('border-l-transparent');
            });

            // Set active class cho dòng được chọn
            if (rowElement) {
                rowElement.classList.remove('border-l-transparent');
                rowElement.classList.add('bg-blue-500/10', 'border-l-blue-500');
            }

            HPUI.toast('Đang tải dữ liệu...', 'info');

            fetch('/Cars/GetCarDetails?plate=' + encodeURIComponent(plate))
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        var car = data.data;
                        window.currentSelectedPlate = car.plate;
                        
                        // Ẩn state trống, hiện panel chi tiết
                        document.getElementById('carEmptyState').classList.add('hidden');
                        document.getElementById('carDetailPanel').classList.remove('hidden');

                        // Cập nhật DOM
                        document.getElementById('detailPlate').textContent = car.plate;
                        var carTitle = [car.brand, car.model].filter(Boolean).join(' ') || car.carModel || 'Chưa cập nhật';
                        if (car.color) carTitle += ' · ' + car.color;
                        document.getElementById('detailBrand').textContent = carTitle;
                        document.getElementById('detailContact').textContent = car.customerName;
                        document.getElementById('detailPhone').textContent = car.customerPhone;

                        // Tạo danh sách lịch sử
                        var historyHtml = '';
                        if (car.history && car.history.length > 0) {
                            car.history.forEach(function(h) {
                                var badgeClass = h.status === 'Đã thanh toán' || h.status === 'completed' 
                                    ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' 
                                    : 'bg-amber-500/10 text-amber-500 border-amber-500/20';
                                
                                var statusText = h.status === 'completed' ? 'Hoàn thành' : h.status;

                                historyHtml += `
                                    <div class="bg-slate-900/50 border border-slate-800 p-4 rounded-lg group relative hover:border-blue-500/50 transition-all opacity-90 hover:opacity-100 cursor-pointer" onclick="HPUI.loadPage('/tickets/${h.ticketId}')">
                                        <div class="flex justify-between items-start mb-4">
                                            <div class="flex-1 pr-4">
                                                <h4 class="text-[13px] font-bold text-slate-200 tracking-wide mb-1.5 line-clamp-1">${h.servicesSummary}</h4>
                                                <div class="flex items-center gap-2"><i data-lucide="history" class="w-3.5 h-3.5 text-slate-500"></i><p class="text-[11px] text-slate-400 font-medium tracking-wider">${h.createdAtStr}</p></div>
                                            </div>
                                            <div class="flex flex-col items-end gap-1.5 shrink-0">
                                                <span class="text-[9px] uppercase font-bold tracking-widest px-2 py-1 rounded border ${badgeClass}">${statusText}</span>
                                                <div class="text-[12px] font-bold text-blue-400 font-mono">${h.totalAmountStr}</div>
                                            </div>
                                        </div>
                                        <div class="border-t border-slate-800 pt-3 flex justify-end"><div class="text-[10px] font-mono text-slate-500 font-medium tracking-widest">${h.ticketCode}</div></div>
                                    </div>
                                `;
                            });
                        } else {
                            historyHtml = '<div class="text-center text-sm text-slate-500 py-4">Không có lịch sử.</div>';
                        }
                        
                        var container = document.getElementById('historyContainer');
                        container.innerHTML = historyHtml;

                        if (window.lucide) window.lucide.createIcons();
                    } else {
                        HPUI.toast(data.message, 'error');
                    }
                })
                .catch(err => {
                    console.error(err);
                    HPUI.toast('Lỗi khi tải dữ liệu xe!', 'error');
                });
        };

        window.createNewTicket = function() {
            var url = '/tickets/new';
            if (window.currentSelectedPlate) {
                url += '?plate=' + encodeURIComponent(window.currentSelectedPlate);
            }
            if (window.HPUI && window.HPUI.loadPage) {
                window.HPUI.loadPage(url);
            } else {
                window.location.href = url;
            }
        };

    })();
</script>
