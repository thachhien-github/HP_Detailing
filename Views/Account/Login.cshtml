@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - HP Auto Detailing</title>
    
    @* Tailwind CSS v3 CDN *@
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            DEFAULT: '#3b82f6',
                            light: 'rgba(59, 130, 246, 0.1)',
                            dark: '#2563eb',
                        },
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Space Grotesk', 'system-ui', 'sans-serif'],
                        mono: ['JetBrains Mono', 'Fira Code', 'monospace'],
                    }
                }
            }
        }
    </script>
    
    @* Google Fonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />

    @* Lucide Icons CDN *@
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

    <style>
        body {
            background-color: #050B14;
            color: #f1f5f9;
        }
        .glass-card {
            background: rgba(18, 33, 49, 0.75);
            border: 1px solid rgba(59, 130, 246, 0.15);
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3), 0 0 30px rgba(59, 130, 246, 0.05);
        }
        .glow-effect {
            box-shadow: 0 0 40px rgba(59, 130, 246, 0.15);
        }
        .hp-input:focus {
            border-color: rgba(59, 130, 246, 0.5) !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1) !important;
        }
        /* Custom loading spinner */
        .spinner {
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-top: 2px solid #ffffff;
            border-radius: 50%;
            width: 1.25rem;
            height: 1.25rem;
            animation: spin 0.8s linear infinite;
        }
        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col relative overflow-hidden font-sans antialiased">
    
    <!-- Decorative Glowing Spots -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] bg-blue-500/10 rounded-full blur-[150px]"></div>
        <div class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[60%] bg-blue-500/5 rounded-full blur-[150px]"></div>
        
        <!-- High-tech Grid Background -->
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+PHBhdGggZD0iTTAgMGg0MHY0MEgwem0zOSAzOUgxdjFoMzh6IiBmaWxsPSJyZ2JhKDU5LCAxMzAsIDI0NiwgMC4wMykiLz48L3N2Zz4=')]"></div>
        
        <!-- Premium Detailing Overlay Image -->
        <div class="absolute inset-0 opacity-10 mix-blend-overlay">
            <img alt="Detailing studio background" class="w-full h-full object-cover grayscale brightness-50" src="https://images.unsplash.com/photo-1607860108855-64acf2078ed9?auto=format&fit=crop&q=80&w=2000" />
        </div>
    </div>

    <!-- Main Content -->
    <main class="flex-grow flex items-center justify-center p-4 sm:p-8 z-10 w-full relative">
        <div class="w-full max-w-[450px] flex flex-col gap-8">
            
            <!-- Logo Section -->
            <div class="text-center space-y-3 flex flex-col items-center">
                <div class="h-16 flex items-center justify-center p-2 bg-slate-900/80 rounded-2xl border border-slate-800 shadow-[0_4px_25px_rgba(59,130,246,0.15)] transition-transform hover:scale-105 duration-300">
                    <img src="/images/logo.png" alt="HP Auto Detailing Logo" class="h-full object-contain" />
                </div>
                <h1 class="font-display text-[12px] font-bold text-blue-400 tracking-[0.25em] uppercase mt-2">HP Auto Detailing - Car Care</h1>
            </div>

            <!-- Login Card -->
            <div class="glass-card rounded-2xl p-8 sm:p-10 shadow-2xl relative overflow-hidden">
                <!-- Top neon line indicator -->
                <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-blue-500 to-transparent"></div>

                <div class="space-y-6">
                    <div class="space-y-1.5">
                        <h2 class="font-display text-2xl font-bold text-slate-100">Đăng nhập</h2>
                        <p class="text-xs text-slate-400">Hệ thống quản lý dịch vụ chăm sóc xe chuyên nghiệp</p>
                    </div>

                    @if (ViewData["ErrorMessage"] != null)
                    {
                        <div class="p-3.5 bg-rose-500/10 border border-rose-500/20 text-rose-400 text-xs font-medium rounded-lg flex items-center gap-2.5">
                            <i data-lucide="alert-circle" class="w-4.5 h-4.5 shrink-0"></i>
                            <span>@ViewData["ErrorMessage"]</span>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post" id="loginForm" class="space-y-5">
                        @Html.AntiForgeryToken()

                        <!-- Username -->
                        <div class="space-y-2">
                            <label class="text-[10px] font-bold tracking-wider text-slate-400 uppercase">Tên đăng nhập</label>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                    <i data-lucide="user" class="w-4.5 h-4.5 text-slate-500 group-focus-within:text-blue-400 transition-colors"></i>
                                </div>
                                <input type="text" name="username" id="username" class="hp-input block w-full pl-11 pr-4 py-3 bg-[#0B101D] border border-slate-800 rounded-lg text-slate-200 placeholder:text-slate-600 outline-none transition-all text-sm" placeholder="Nhập tên đăng nhập..." required autocomplete="off" />
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="space-y-2">
                            <div class="flex justify-between items-center">
                                <label class="text-[10px] font-bold tracking-wider text-slate-400 uppercase">Mật khẩu</label>
                                <a class="text-[10px] font-bold text-blue-400 hover:text-blue-300 transition-colors uppercase tracking-wider" href="#">Quên mật khẩu?</a>
                            </div>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                    <i data-lucide="lock" class="w-4.5 h-4.5 text-slate-500 group-focus-within:text-blue-400 transition-colors"></i>
                                </div>
                                <input type="password" name="password" id="password" class="hp-input block w-full pl-11 pr-11 py-3 bg-[#0B101D] border border-slate-800 rounded-lg text-slate-200 placeholder:text-slate-600 outline-none transition-all text-sm" placeholder="••••••••" required />
                                <button type="button" onclick="togglePasswordVisibility()" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-slate-500 hover:text-slate-300 transition-colors">
                                    <i data-lucide="eye" id="eyeIcon" class="w-4.5 h-4.5"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Remember Login -->
                        <div class="flex items-center gap-2 pt-1 pb-1">
                            <input id="remember" type="checkbox" class="w-4 h-4 rounded border-slate-800 bg-[#0B101D] text-blue-500 focus:ring-0 focus:ring-offset-0 cursor-pointer transition-all" />
                            <label for="remember" class="text-xs text-slate-400 select-none cursor-pointer hover:text-slate-300 transition-colors font-medium">Ghi nhớ phiên đăng nhập</label>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" id="btnSubmit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-display text-[15px] font-bold py-3.5 rounded-lg shadow-lg hover:shadow-blue-500/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2 group mt-2">
                            <span id="btnText">Xác thực hệ thống</span>
                            <span id="btnSpinner" class="spinner hidden"></span>
                            <i data-lucide="arrow-right" id="btnIcon" class="w-4.5 h-4.5 group-hover:translate-x-1 transition-transform"></i>
                        </button>
                    </form>
                </div>
            </div>

            <!-- Help Contact -->
            <div class="flex flex-col items-center gap-2 text-xs text-slate-500 z-10">
                <p>Gặp sự cố truy cập? <a class="text-blue-400 font-medium hover:underline hover:text-blue-300 transition-colors" href="#">Liên hệ hỗ trợ kỹ thuật</a></p>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="z-10 w-full py-5 px-4 sm:px-10 border-t border-slate-900/50 bg-[#050B14]/80 backdrop-blur-md mt-auto">
        <div class="max-w-[1440px] mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest">
            <div class="flex items-center gap-4">
                <span>© @DateTime.Now.Year HP Auto Detailing</span>
                <span class="h-1.5 w-1.5 bg-slate-800 rounded-full hidden md:block"></span>
                <span class="text-blue-500 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse hidden sm:block"></span> Hệ thống vận hành nội bộ
                </span>
            </div>
            <div class="flex gap-6">
                <a class="hover:text-blue-400 transition-colors" href="#">Điều khoản</a>
                <a class="hover:text-blue-400 transition-colors" href="#">Bảo mật</a>
                <a class="hover:text-blue-400 transition-colors" href="#">Hỗ trợ</a>
            </div>
        </div>
    </footer>

    <script>
        // Init Lucide
        if (window.lucide) {
            lucide.createIcons();
        }

        // Toggle password visibility
        function togglePasswordVisibility() {
            var passwordInput = document.getElementById('password');
            var eyeIcon = document.getElementById('eyeIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeIcon.setAttribute('data-lucide', 'eye-off');
            } else {
                passwordInput.type = 'password';
                eyeIcon.setAttribute('data-lucide', 'eye');
            }
            if (window.lucide) {
                lucide.createIcons();
            }
        }

        // Handle button loading animation on submit
        var form = document.getElementById('loginForm');
        var btnSubmit = document.getElementById('btnSubmit');
        var btnText = document.getElementById('btnText');
        var btnSpinner = document.getElementById('btnSpinner');
        var btnIcon = document.getElementById('btnIcon');

        if (form && btnSubmit) {
            form.addEventListener('submit', function() {
                btnSubmit.disabled = true;
                btnText.textContent = "Đang xác thực...";
                btnSpinner.classList.remove('hidden');
                btnIcon.classList.add('hidden');
            });
        }
    </script>
</body>
</html>
