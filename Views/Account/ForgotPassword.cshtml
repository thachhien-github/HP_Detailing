@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_PublicLayout";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 relative bg-[#060B14] overflow-hidden">
    <!-- Nền trang -->
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1601362840469-51e4d8d58785?auto=format&fit=crop&q=80')] bg-cover bg-center opacity-10"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#060B14] via-[#060B14]/80 to-transparent"></div>
    </div>

    <!-- Hộp nội dung -->
    <div class="max-w-md w-full space-y-8 relative z-10 bg-[#0B101D]/80 backdrop-blur-md p-10 rounded-3xl border border-outline-variant/30 shadow-2xl">
        <div>
            <div class="flex justify-center mb-6">
                <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center border border-blue-500/30 shadow-lg shadow-blue-500/20">
                    <span class="material-symbols-outlined text-4xl text-blue-400">lock_reset</span>
                </div>
            </div>
            <h2 class="text-center text-3xl font-bold text-white mb-2">Khôi phục mật khẩu</h2>
            <p class="text-center text-sm text-slate-400 mb-8">Tính năng gửi email tự động đang được bảo trì. Vui lòng liên hệ Quản trị viên để được cấp lại mật khẩu.</p>
        </div>
        
        <div class="bg-blue-500/10 border border-blue-500/20 p-5 rounded-2xl mb-6">
            <h3 class="text-sm font-bold text-blue-400 mb-2 flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">contact_support</span> Thông tin liên hệ
            </h3>
            <ul class="text-sm text-slate-300 space-y-2">
                <li><strong class="text-white">Hotline:</strong> 0987.654.321</li>
                <li><strong class="text-white">Email:</strong> support@hpdetailing.vn</li>
                <li><strong class="text-white">Giờ làm việc:</strong> 08:00 - 18:00 (T2-T7)</li>
            </ul>
        </div>

        <div class="flex items-center justify-center">
            <a href="/Account/Login" class="text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">arrow_back</span>
                Quay lại trang đăng nhập
            </a>
        </div>
    </div>
</div>
