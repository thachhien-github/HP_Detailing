<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HP Auto Detailing</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&family=Metropolis:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Shared Tailwind Config -->
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-dim": "#131313",
                        "secondary-container": "#484949",
                        "on-error": "#690005",
                        "on-tertiary-fixed": "#1c1b1b",
                        "outline": "#ad887e",
                        "on-primary-container": "#541100",
                        "surface-container-lowest": "#0e0e0e",
                        "surface": "#131313",
                        "surface-container-highest": "#353534",
                        "surface-container": "#201f1f",
                        "on-background": "#e5e2e1",
                        "surface-tint": "#ffb5a0",
                        "outline-variant": "#5d4038",
                        "surface-container-low": "#1c1b1b",
                        "on-primary": "#601400",
                        "error": "#ffb4ab",
                        "on-tertiary-container": "#2a2a2a",
                        "secondary": "#c6c6c6",
                        "surface-variant": "#353534",
                        "on-primary-fixed-variant": "#872000",
                        "primary-fixed-dim": "#ffb5a0",
                        "background": "#131313",
                        "surface-bright": "#3a3939",
                        "on-secondary-container": "#b8b8b8",
                        "on-error-container": "#ffdad6",
                        "on-surface-variant": "#e7bdb2",
                        "tertiary": "#c8c6c5",
                        "on-secondary-fixed-variant": "#464747",
                        "tertiary-fixed": "#e5e2e1",
                        "tertiary-container": "#929090",
                        "on-tertiary-fixed-variant": "#474746",
                        "inverse-primary": "#b12d00",
                        "primary-fixed": "#ffdbd1",
                        "secondary-fixed-dim": "#c6c6c6",
                        "inverse-surface": "#e5e2e1",
                        "tertiary-fixed-dim": "#c8c6c5",
                        "primary": "#ffb5a0",
                        "error-container": "#93000a",
                        "on-tertiary": "#313030",
                        "on-secondary-fixed": "#1a1c1c",
                        "on-surface": "#e5e2e1",
                        "on-primary-fixed": "#3b0900",
                        "on-secondary": "#2f3131",
                        "primary-container": "#ff5625",
                        "surface-container-high": "#2a2a2a",
                        "secondary-fixed": "#e3e2e2",
                        "inverse-on-surface": "#313030"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "margin-mobile": "16px",
                        "xs": "4px",
                        "sm": "12px",
                        "xl": "80px",
                        "gutter": "24px",
                        "margin-desktop": "64px",
                        "md": "24px",
                        "base": "8px",
                        "lg": "48px"
                    },
                    "fontFamily": {
                        "body-md": ["Metropolis", "system-ui", "sans-serif"],
                        "display-lg": ["Montserrat", "system-ui", "sans-serif"],
                        "headline-md": ["Montserrat", "system-ui", "sans-serif"],
                        "headline-sm": ["Montserrat", "system-ui", "sans-serif"],
                        "caption": ["Metropolis", "system-ui", "sans-serif"],
                        "label-bold": ["Metropolis", "system-ui", "sans-serif"],
                        "display-lg-mobile": ["Montserrat", "system-ui", "sans-serif"],
                        "body-lg": ["Metropolis", "system-ui", "sans-serif"]
                    },
                    "fontSize": {
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "800"}],
                        "headline-md": ["32px", {"lineHeight": "40px", "fontWeight": "700"}],
                        "headline-sm": ["24px", {"lineHeight": "32px", "fontWeight": "700"}],
                        "caption": ["12px", {"lineHeight": "16px", "fontWeight": "500"}],
                        "label-bold": ["14px", {"lineHeight": "20px", "letterSpacing": "0.1em", "fontWeight": "700"}],
                        "display-lg-mobile": ["36px", {"lineHeight": "42px", "letterSpacing": "-0.02em", "fontWeight": "800"}],
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>
    <style>
        body {
            background-color: #0D0D0D;
            color: #e5e2e1;
            font-family: 'Metropolis', sans-serif;
            overflow-x: hidden;
            color-scheme: dark;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        .high-gloss-card {
            background-color: #1A1A1A;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .high-gloss-card:hover {
            border-color: #ffb5a0;
            box-shadow: 0 0 20px rgba(255, 181, 160, 0.15);
            transform: translateY(-4px);
        }

        .btn-primary {
            background: linear-gradient(to bottom, #ff7b52, #ff5625);
            transition: transform 0.2s active:scale-95;
        }

        .btn-primary:hover {
            box-shadow: 0 0 15px rgba(255, 86, 37, 0.4);
        }

        .btn-secondary {
            border: 2px solid #c6c6c6;
            transition: background 0.3s ease;
        }

        .btn-secondary:hover {
            background: rgba(198, 198, 198, 0.1);
        }

        .performance-gauge {
            height: 4px;
            background: #2a2a2a;
            display: flex;
            gap: 2px;
        }

        .gauge-segment {
            flex: 1;
            background: #ff5625;
        }

        .glass-nav {
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        .rim-light {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            border-left: 1px solid rgba(255, 255, 255, 0.1);
        }

        .input-dark, select.input-dark, textarea.input-dark {
            background: #050505 !important;
            color: #ffffff !important;
            border: 1px solid #353534;
            transition: all 0.3s ease;
        }

        .input-dark option {
            background-color: #050505 !important;
            color: #ffffff !important;
        }

        .input-dark:focus {
            border-color: #ff5625;
            outline: none;
            box-shadow: 0 0 8px rgba(255, 86, 37, 0.3);
        }

        .stat-item::after {
            content: '';
            position: absolute;
            right: 0;
            top: 20%;
            height: 60%;
            width: 1px;
            background: linear-gradient(to bottom, transparent, rgba(255, 86, 37, 0.4), transparent);
        }
        .stat-item:last-child::after { display: none; }

        .price-card.featured {
            border-color: #ff5625;
            background: linear-gradient(145deg, #201f1f 0%, #131313 100%);
            transform: scale(1.05);
            z-index: 10;
        }
    </style>
</head>
<body class="bg-background text-on-background antialiased">
    @RenderBody()
    
    <!-- WhatsApp Floating Button -->
    <a href="https://wa.me/84987654321?text=Xin%20ch%C3%A0o%2C%20t%C3%B4i%20mu%E1%BB%91n%20t%C3%ACm%20hi%E1%BB%83u%20v%E1%BB%81%20d%E1%BB%8Bch%20v%E1%BB%A5%20detailing%20c%E1%BB%A7a%20HP%20Auto" 
       class="fixed bottom-6 right-4 md:bottom-8 md:right-8 z-40 flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full bg-green-500 hover:bg-green-600 shadow-lg hover:shadow-xl hover:scale-110 transition-all duration-300 animate-bounce"
       target="_blank"
       rel="noopener noreferrer"
       title="Liên hệ qua WhatsApp">
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.948 1.253l-.354.214-3.675-.964.984 3.202-.22.354a9.86 9.86 0 00-1.51 5.26c0 5.446 4.435 9.884 9.885 9.884 1.71 0 3.313-.342 4.851-1.011 1.537-.67 2.92-1.631 3.994-2.705a9.844 9.844 0 002.705-3.994 9.875 9.875 0 001.01-4.851c0-5.45-4.434-9.884-9.885-9.884z"/>
        </svg>
    </a>

    <!-- Messenger Floating Button -->
    <a href="https://m.me/hpautodetailing" 
       class="fixed bottom-[76px] md:bottom-24 right-4 md:right-8 z-40 flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full bg-blue-500 hover:bg-blue-600 shadow-lg hover:shadow-xl hover:scale-110 transition-all duration-300"
       target="_blank"
       rel="noopener noreferrer"
       title="Liên hệ qua Messenger">
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
        </svg>
    </a>

    <!-- Floating Button Info Tooltip -->
    <style>
        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-bounce {
            animation: bounce 2s infinite;
        }
    </style>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
