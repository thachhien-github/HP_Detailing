@* Sidebar partial mapped from src/components/layout/Sidebar.tsx *@
@{
    var requestPath = Context.Request.Path.HasValue ? Context.Request.Path.Value! : "";

    Func<string, bool> isActive = (string href) =>
        href == "/"
            ? (requestPath == "/" || requestPath == "")
            : !string.IsNullOrWhiteSpace(href) && requestPath.StartsWith(href, System.StringComparison.OrdinalIgnoreCase);
}

<div class="fixed inset-y-0 left-0 z-50 flex w-64 flex-col bg-[#0B101D] transition-transform duration-300 ease-in-out lg:static lg:translate-x-0 border-r border-slate-800/50 -translate-x-full" id="hpSidebar">

    <div class="flex h-24 shrink-0 items-center justify-center px-4 sm:px-6 border-b border-slate-800/50 relative">
        <a href="/" class="flex items-center justify-center">
            <div class="h-16 flex items-center justify-center overflow-hidden">
                <img src="/images/logo.png" alt="HP AUTO Logo" class="h-full object-contain" />
            </div>
        </a>
        <button type="button" class="lg:hidden absolute right-4 text-slate-400 hover:text-white" onclick="window.HPUI?.closeSidebar?.()">
            <i data-lucide="chevron-left" class="w-5 h-5"></i>
        </button>
    </div>

    <div class="flex flex-1 flex-col overflow-y-auto pt-6 custom-scrollbar">
        <nav class="flex-1 space-y-1.5 px-3">
            @{
                var navItems = new[]
                {
                    new { href = "/", icon = "layout-dashboard", label = "Tổng quan" },
                    new { href = "/appointments", icon = "calendar-clock", label = "Lịch hẹn" },
                    new { href = "/tickets", icon = "clipboard-list", label = "Tiếp nhận dịch vụ" },
                    new { href = "/catalog", icon = "grid", label = "Danh mục dịch vụ" },
                    new { href = "/cars", icon = "car", label = "Quản lý phương tiện" },
                    new { href = "/warehouse", icon = "warehouse", label = "Kho phụ tùng" },
                    new { href = "/staff", icon = "users", label = "Nhân sự" },
                    new { href = "/financial", icon = "receipt", label = "Hóa đơn & Thanh toán" },
                    new { href = "/analytics", icon = "bar-chart-3", label = "Báo cáo & Phân tích" },
                };
            }

            @foreach (var item in navItems)
            {
                var active = item.href == "/"
                    ? (requestPath == "/" || requestPath == "") && requestPath != "/login"
                    : requestPath.StartsWith(item.href, System.StringComparison.OrdinalIgnoreCase);

                <a class="group flex items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-all relative @(active ? "bg-blue-500/10 text-white" : "text-slate-400 hover:bg-slate-800/30 hover:text-white")"
                   href="@item.href" onclick="window.HPUI?.closeSidebar?.()">
                    @if (active)
                    {
                        <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-6 bg-blue-500 rounded-r-md shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                    }
                    <span class="mr-3 shrink-0">
                        <i data-lucide="@item.icon" class="w-[18px] h-[18px] @(active ? "text-blue-400" : "text-slate-500 group-hover:text-slate-300")"></i>
                    </span>
                    @item.label
                </a>
            }
        </nav>
    </div>

    <div class="p-4 flex flex-col gap-2 mt-auto border-t border-slate-800/50">
        <a href="/tickets/new"
           class="flex w-full items-center justify-center gap-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white px-4 py-2.5 text-sm font-bold transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)] hover:shadow-[0_0_20px_rgba(59,130,246,0.4)] mb-2"
           onclick="window.HPUI?.closeSidebar?.()">
            <i data-lucide="plus" class="w-4 h-4"></i>
            Tạo phiếu mới
        </a>

        <div class="space-y-1">
            <a href="/settings"
               class="group flex items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-400 hover:bg-slate-800/50 hover:text-white transition-colors @(requestPath.StartsWith("/settings", System.StringComparison.OrdinalIgnoreCase) ? "bg-slate-800/50 text-white" : "")"
               onclick="window.HPUI?.closeSidebar?.()">
                <i data-lucide="settings" class="w-[18px] h-[18px] mr-3 text-slate-500 group-hover:text-slate-300"></i>
                Cài đặt
            </a>
            <a href="/Account/Logout"
               class="group flex w-full items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-400 hover:bg-slate-800/50 hover:text-white transition-colors"
               onclick="window.HPUI?.closeSidebar?.()">
                <i data-lucide="log-out" class="w-[18px] h-[18px] mr-3 text-slate-500 group-hover:text-slate-300"></i>
                Đăng xuất
            </a>
        </div>
    </div>
</div>
