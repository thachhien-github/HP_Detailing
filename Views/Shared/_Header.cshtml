@using Microsoft.AspNetCore.Identity
@using HP_Detailing.Models
@inject UserManager<AppUser> UserManager
@* Header partial mapped from src/components/layout/Header.tsx *@
@{
    var appUser = await UserManager.GetUserAsync(User);
    var fullName = appUser?.FullName ?? User.Identity?.Name ?? "Người dùng";
    var avatarUrl = appUser?.AvatarUrl ?? "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80";
    var roles = appUser != null ? await UserManager.GetRolesAsync(appUser) : new List<string>();
    var roleDisplay = roles.FirstOrDefault() ?? "Guest";
}
<header class="sticky top-0 z-40 flex h-16 shrink-0 items-center gap-x-4 border-b border-slate-800/50 bg-[#0B101D]/95 backdrop-blur-md px-4 sm:gap-x-6 sm:px-6 lg:px-8">
    <button type="button" class="-m-2.5 p-2.5 text-slate-400 lg:hidden hover:text-white transition-colors" onclick="window.HPUI?.openSidebar?.()">
        <span class="sr-only">Open sidebar</span>
        <i data-lucide="menu" class="w-5 h-5"></i>
    </button>

    <div class="flex flex-1 gap-x-4 self-stretch lg:gap-x-6 items-center">
        <a href="/" class="lg:hidden flex items-center gap-2 shrink-0">
            <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-lg shadow-blue-500/20">
                <i data-lucide="sparkles" class="w-4 h-4 text-white"></i>
            </div>
            <span class="text-sm font-bold text-white tracking-tight hidden xs:block">HP AUTO</span>
        </a>

        <form class="relative flex flex-1 max-w-md lg:max-w-xl transition-all" action="#" method="get">
            <label class="sr-only" for="search-field">Tìm kiếm</label>
            <i data-lucide="search" class="pointer-events-none absolute inset-y-0 left-3.5 my-auto w-4 h-4 text-slate-500"></i>
            <input id="search-field"
                   class="block h-10 w-full rounded-xl border border-slate-800/80 bg-[#122131]/50 py-2 pl-11 pr-3 text-sm text-white placeholder:text-slate-600 focus:border-blue-500/50 focus:bg-[#122131] focus:ring-2 focus:ring-blue-500/10 focus:outline-none transition-all"
                   placeholder="Tìm kiếm biển số, khách hàng..." type="search" name="search" />
        </form>

        <div class="flex items-center gap-x-3 lg:gap-x-4 ml-auto">
            @* Notifications dropdown *@
            <div class="flex items-center gap-2 border-r border-slate-800/80 pr-3 lg:pr-5 relative">
                <div class="relative" data-hp-dropdown>
                    <button type="button" class="p-2 text-slate-400 hover:text-white transition-colors relative group rounded-lg hover:bg-slate-800/50" data-hp-dropdown-toggle="notifications">
                        <span class="sr-only">View notifications</span>
                        <i data-lucide="bell" class="w-5 h-5"></i>
                        <span class="absolute top-1.5 right-1.5 h-2 w-2 rounded-full bg-blue-500 ring-2 ring-[#0B101D] group-hover:scale-110 transition-transform"></span>
                    </button>

                    <div class="absolute right-0 mt-3 w-80 sm:w-[400px] bg-[#122131] border border-slate-700/50 rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.6)] z-50 overflow-hidden" data-hp-dropdown-panel>
                        <div class="px-5 py-4 border-b border-slate-700/50 bg-[#0B101D]/80 backdrop-blur-md flex items-center justify-between">
                            <div>
                                <h3 class="text-sm font-bold text-white">Thông báo</h3>
                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mt-0.5">3 tin nhắn mới</p>
                            </div>
                            <button type="button" class="text-[10px] uppercase font-bold text-blue-400 hover:text-blue-300 transition-colors bg-blue-500/5 px-2 py-1 rounded-md border border-blue-500/20">Đã đọc tất cả</button>
                        </div>
                        <div class="max-h-[420px] overflow-y-auto w-full custom-scrollbar">
                            <div class="group relative flex gap-4 p-4 hover:bg-slate-800/40 transition-all border-b border-slate-800/30 cursor-pointer bg-blue-500/[0.03]">
                                <div class="shrink-0 mt-0.5">
                                    <div class="w-10 h-10 rounded-xl flex items-center justify-center border bg-emerald-500/10 border-emerald-500/20 text-emerald-400">
                                        <i data-lucide="check-circle-2" class="w-5 h-5"></i>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0 pr-6">
                                    <div class="flex items-center gap-2">
                                        <p class="text-sm font-bold text-white">Dịch vụ hoàn tất</p>
                                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                    </div>
                                    <p class="text-xs text-slate-400 mt-1 leading-relaxed line-clamp-2">Xe Mercedes GLC 300 (51H-123.45) đã hoàn thành gói đánh bóng Ceramic.</p>
                                    <p class="text-[10px] text-slate-500 font-bold mt-2 uppercase tracking-tight">10 phút trước</p>
                                </div>
                            </div>
                            <div class="group relative flex gap-4 p-4 hover:bg-slate-800/40 transition-all border-b border-slate-800/30 cursor-pointer">
                                <div class="shrink-0 mt-0.5">
                                    <div class="w-10 h-10 rounded-xl flex items-center justify-center border bg-blue-500/10 border-blue-500/20 text-blue-400">
                                        <i data-lucide="calendar-clock" class="w-5 h-5"></i>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0 pr-6">
                                    <div class="flex items-center gap-2">
                                        <p class="text-sm font-bold text-white">Lịch hẹn mới</p>
                                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                                    </div>
                                    <p class="text-xs text-slate-400 mt-1 leading-relaxed line-clamp-2">Khách hàng Nguyễn Văn A đặt lịch hẹn rửa xe ngày 20/05.</p>
                                    <p class="text-[10px] text-slate-500 font-bold mt-2 uppercase tracking-tight">30 phút trước</p>
                                </div>
                            </div>
                            <div class="group relative flex gap-4 p-4 hover:bg-slate-800/40 transition-all cursor-pointer">
                                <div class="shrink-0 mt-0.5">
                                    <div class="w-10 h-10 rounded-xl flex items-center justify-center border bg-amber-500/10 border-amber-500/20 text-amber-400">
                                        <i data-lucide="alert-triangle" class="w-5 h-5"></i>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0 pr-6">
                                    <div class="flex items-center gap-2">
                                        <p class="text-sm font-bold text-white">Kho sắp hết hàng</p>
                                    </div>
                                    <p class="text-xs text-slate-400 mt-1 leading-relaxed line-clamp-2">Dung dịch rửa xe bọt tuyết còn 2 thùng. Cần nhập thêm.</p>
                                    <p class="text-[10px] text-slate-500 font-bold mt-2 uppercase tracking-tight">1 giờ trước</p>
                                </div>
                            </div>
                        </div>
                        <div class="p-3 border-t border-slate-700/50 bg-[#0B101D]/50 text-center">
                            <button type="button" class="text-xs font-bold text-slate-400 hover:text-white transition-all py-1 w-full hover:bg-slate-800/40 rounded-lg tracking-widest uppercase">Xem tất cả thông báo</button>
                        </div>
                    </div>
                </div>
            </div>

            @* History dropdown *@
            <div class="relative" data-hp-dropdown>
                <button type="button" class="p-2 text-slate-400 hover:text-white transition-colors rounded-lg hover:bg-slate-800/50" data-hp-dropdown-toggle="history" title="Lịch sử">
                    <i data-lucide="history" class="w-5 h-5"></i>
                </button>
                <div class="absolute right-0 mt-3 w-72 bg-[#122131] border border-slate-700/50 rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.6)] z-50 overflow-hidden" data-hp-dropdown-panel>
                    <div class="px-4 py-3 border-b border-slate-700/50 bg-[#0B101D]/80 flex items-center justify-between">
                        <h3 class="text-xs font-bold text-white uppercase tracking-widest">Hoạt động gần đây</h3>
                    </div>
                    <div class="max-h-80 overflow-y-auto custom-scrollbar">
                        <div class="p-3.5 border-b border-slate-800/50 hover:bg-slate-800/30 transition-colors cursor-pointer">
                            <p class="text-xs font-bold text-blue-400">#HP-0942</p>
                            <p class="text-[11px] text-slate-200 mt-1">Đã thanh toán hóa đơn Rửa xe Gold</p>
                            <p class="text-[10px] text-slate-500 mt-1.5">10 phút trước</p>
                        </div>
                        <div class="p-3.5 border-b border-slate-800/50 hover:bg-slate-800/30 transition-colors cursor-pointer">
                            <p class="text-xs font-bold text-amber-400">#PDV-2405-0082</p>
                            <p class="text-[11px] text-slate-200 mt-1">Bắt đầu thi công Phủ Ceramic 9H</p>
                            <p class="text-[10px] text-slate-500 mt-1.5">1 giờ trước</p>
                        </div>
                        <div class="p-3.5 hover:bg-slate-800/30 transition-colors cursor-pointer">
                            <p class="text-xs font-bold text-emerald-400">Nhập kho</p>
                            <p class="text-[11px] text-slate-200 mt-1">Đã nhập 20 lọ Ceramic Diamond 9H</p>
                            <p class="text-[10px] text-slate-500 mt-1.5">Hôm qua</p>
                        </div>
                    </div>
                    <a href="/analytics" class="block p-3 text-center text-[10px] font-bold text-slate-400 hover:text-white bg-[#0B101D]/50 border-t border-slate-700/50 uppercase tracking-widest">Xem báo cáo chi tiết</a>
                </div>
            </div>

            @* Support dropdown *@
            <div class="relative" data-hp-dropdown>
                <button type="button" class="p-2 text-slate-400 hover:text-white transition-colors rounded-lg hover:bg-slate-800/50" data-hp-dropdown-toggle="support" title="Hỗ trợ">
                    <i data-lucide="help-circle" class="w-5 h-5"></i>
                </button>
                <div class="absolute right-0 mt-3 w-64 bg-[#122131] border border-slate-700/50 rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.6)] z-50 overflow-hidden" data-hp-dropdown-panel>
                    <div class="px-4 py-3 border-b border-slate-700/50 bg-[#0B101D]/80">
                        <h3 class="text-xs font-bold text-white uppercase tracking-widest">Trung tâm hỗ trợ</h3>
                    </div>
                    <div class="p-2 space-y-1">
                        <button onclick="HPUI.toast('Đang kết nối tổng đài: 0987.654.321', 'info')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800/50 transition-colors group">
                            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 group-hover:bg-emerald-500 group-hover:text-white transition-all">
                                <i data-lucide="phone" class="w-4 h-4"></i>
                            </div>
                            <div class="text-left">
                                <p class="text-xs font-bold text-slate-200">Hotline kỹ thuật</p>
                                <p class="text-[10px] text-slate-500">0987.654.321</p>
                            </div>
                        </button>
                        <a href="/support" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800/50 transition-colors group">
                            <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 group-hover:bg-blue-500 group-hover:text-white transition-all">
                                <i data-lucide="book" class="w-4 h-4"></i>
                            </div>
                            <div class="text-left">
                                <p class="text-xs font-bold text-slate-200">Hướng dẫn sử dụng</p>
                                <p class="text-[10px] text-slate-500">Tài liệu & Video</p>
                            </div>
                        </a>
                        <button onclick="HPUI.toast('Yêu cầu hỗ trợ đã được gửi tới quản trị viên!', 'success')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800/50 transition-colors group">
                            <div class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center text-purple-400 group-hover:bg-purple-500 group-hover:text-white transition-all">
                                <i data-lucide="message-square" class="w-4 h-4"></i>
                            </div>
                            <div class="text-left">
                                <p class="text-xs font-bold text-slate-200">Báo lỗi hệ thống</p>
                                <p class="text-[10px] text-slate-500">Phản hồi nhanh</p>
                            </div>
                        </button>
                    </div>
                </div>
            </div>

            @* Profile *@
            <a href="/profile" class="flex items-center gap-x-3 p-1.5 rounded-xl hover:bg-slate-800/40 transition-all border border-transparent hover:border-slate-800 group">
                <div class="flex flex-col text-right hidden lg:flex">
                    <span class="text-sm font-bold text-slate-100 group-hover:text-blue-400 transition-colors leading-none">@fullName</span>
                    <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mt-0.5">@roleDisplay • Active</span>
                </div>
                <div class="relative">
                    <img class="h-9 w-9 rounded-lg bg-slate-800 object-cover ring-1 ring-slate-700/50 group-hover:ring-blue-500/50 transition-all shadow-lg" src="@avatarUrl" alt="Profile" />
                    <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-emerald-500 border-2 border-[#0B101D] rounded-full shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
                </div>
            </a>
        </div>
    </div>
</header>
